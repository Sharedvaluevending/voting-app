# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/votingApp

# Session (required for persistent sessions)
SESSION_SECRET=your-random-secret-here

# Base URL for password reset links (e.g. https://yoursite.com)
BASE_URL=https://yoursite.com

# Google OAuth (for "Sign in with Google")
# Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Callback URL - set to your app URL (Render sets RENDER_EXTERNAL_URL automatically)
GOOGLE_CALLBACK_URL=https://yoursite.com/auth/google/callback

# Email for password reset (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-password
MAIL_FROM=noreply@yoursite.com

# Jupiter Token API (free at https://portal.jup.ag/api-keys) - for trench warfare 400+ coin scanning
JUPITER_API_KEY=

# DeepSeek API (https://platform.deepseek.com) - when set, agent & chat use DeepSeek instead of Ollama
DEEPSEEK_API_KEY=

# Voice Copilot
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
PIPER_BIN=piper
PIPER_MODEL=/opt/piper/en_US-amy-medium.onnx
PIPER_SPEAKER=
VOICE_TRANSPORT=http
MUMBLE_ENABLED=false
MUMBLE_HOST=127.0.0.1
MUMBLE_PORT=64738

# Web Push (trades & action badges) - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:support@yoursite.com

# Redis (required for production scalability)
REDIS_URL=redis://127.0.0.1:6379

# Sentry error tracking (https://sentry.io)
SENTRY_DSN=

# Stripe Billing (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx
