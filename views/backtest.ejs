<%- include('partials/header') %>

<style>
/* Backtest page – mobile card layout for tables, glass background */
.backtest-page .section { background: rgba(15,23,42,0.6); border: 1px solid #1e2a3a; }
.backtest-page #bt-coins-table,
.backtest-page #bt-trades-table { background: rgba(15,23,42,0.4); }
@media (max-width: 600px) {
  .backtest-page .section-header h2 { font-size: 18px; }
  .backtest-page .section { padding: 12px; }
  .backtest-page #bt-coins-table,
  .backtest-page #bt-trades-table { width: 100%; max-width: 100%; }
  .backtest-page .per-coin-wrap,
  .backtest-page .trade-list-wrap { overflow-x: visible; width: 100%; }
}
</style>

<div class="backtest-page main-content-inner">
<div class="section-header">
  <h2 style="color:#fff;font-size:22px;">Historical Backtest</h2>
  <p style="color:#9ca3af;font-size:13px;margin-top:6px;">Simulate the full trading engine on historical candles. Toggle features to compare performance.</p>
</div>

<!-- Backtest Methodology (backtest-expert skill) -->
<div class="section" style="margin-bottom:20px;padding:16px;background:rgba(234,179,8,0.06);border:1px solid rgba(234,179,8,0.2);border-radius:8px;">
  <h3 style="color:#eab308;font-size:12px;margin:0 0 8px 0;text-transform:uppercase;letter-spacing:0.5px;">Backtest Methodology</h3>
  <ul style="margin:0;padding-left:18px;font-size:12px;color:#9ca3af;line-height:1.6;">
    <li><strong style="color:#e5e7eb;">Sample size</strong> — Aim for 30+ trades minimum; 100+ for higher confidence.</li>
    <li><strong style="color:#e5e7eb;">Stress test</strong> — Try different min scores; if results collapse on small changes, strategy may be fragile.</li>
    <li><strong style="color:#e5e7eb;">Walk-forward</strong> — Use train/test split to validate out-of-sample performance.</li>
  </ul>
</div>

<!-- Form -->
<div class="section" style="margin-bottom:24px;">
  <h3 style="color:#e5e7eb;margin-bottom:12px;">Backtest Parameters</h3>
  <form id="backtest-form" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;align-items:end;">
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Coin</label>
      <select name="coinId" id="coinId" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <option value="">All coins (first 3, ~25s)</option>
        <% if (typeof TRACKED_COINS !== 'undefined' && TRACKED_COINS) { %>
          <% TRACKED_COINS.forEach(function(cid) { %>
            <option value="<%= cid %>"><%= cid %></option>
          <% }); %>
        <% } else { %>
          <option value="bitcoin">bitcoin</option>
          <option value="ethereum">ethereum</option>
          <option value="solana">solana</option>
        <% } %>
      </select>
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Start Date</label>
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="date" name="startDate" id="startDate" style="flex:1;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <div style="display:flex;gap:4px;flex-shrink:0;">
          <button type="button" class="nav-btn" style="padding:6px 12px;font-size:11px;" title="Set to 6 months ago" id="bt-preset-6m">6m</button>
          <button type="button" class="nav-btn" style="padding:6px 12px;font-size:11px;" title="Set to 1 year ago" id="bt-preset-1y">1yr</button>
        </div>
      </div>
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">End Date</label>
      <input type="date" name="endDate" id="endDate" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Min Score</label>
      <input type="number" name="minScore" id="minScore" value="52" min="40" max="80" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Leverage</label>
      <input type="number" name="leverage" id="leverage" value="2" min="1" max="10" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Initial Balance ($)</label>
      <input type="number" name="initialBalance" id="initialBalance" value="10000" min="100" max="1000000" step="1" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Risk Mode</label>
      <select name="riskMode" id="riskMode" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <option value="percent">% of balance</option>
        <option value="dollar">Fixed $ per trade</option>
      </select>
    </div>
    <div id="bt-risk-pct-wrap">
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Risk per trade (%)</label>
      <input type="number" name="riskPerTrade" id="riskPerTrade" value="2" min="0.1" max="10" step="0.1" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div id="bt-risk-dollar-wrap" style="display:none;">
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Risk per trade ($)</label>
      <input type="number" name="riskDollarsPerTrade" id="riskDollarsPerTrade" value="200" min="1" max="10000" step="1" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Timeframe</label>
      <select name="primaryTf" id="primaryTf" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;" title="Primary candle timeframe for trade signals. Higher TFs (4h, 1d, 1w) are always used as context.">
        <option value="15m">15 min</option>
        <option value="1h" selected>1 hour (default)</option>
        <option value="4h">4 hour</option>
        <option value="1d">Daily</option>
        <option value="1w">Weekly</option>
      </select>
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Mode</label>
      <select name="btMode" id="btMode" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <option value="single">Single run</option>
        <option value="walkforward">Walk-forward (train/test split)</option>
        <option value="sweep">Parameter sweep</option>
      </select>
    </div>
    <div id="bt-walkforward-opts" style="display:none;">
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Train %</label>
      <input type="number" id="btTrainPct" value="70" min="50" max="90" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-top:10px;" title="After training runs, writes regime win/loss data to strategy weights. The live system will then prefer or avoid strategies in regimes where they underperform.">
        <input type="checkbox" id="btApplyTraining" style="width:14px;height:14px;cursor:pointer;">
        <span style="font-size:12px;color:#9ca3af;">Apply training results to strategy weights</span>
      </label>
      <p style="font-size:11px;color:#6b7280;margin:4px 0 0 22px;">Teaches the live system to reduce trades in losing regimes (e.g. ranging).</p>
      <div id="bt-apply-training-status" style="display:none;margin-top:8px;padding:8px 12px;border-radius:6px;font-size:12px;"></div>
    </div>
    <div id="bt-sweep-opts" style="display:none;">
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Sweep Min Score (comma-sep)</label>
      <input type="text" id="btSweepMinScore" value="48,52,56" placeholder="48,52,56" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
      <button type="submit" class="btn btn-primary" id="run-btn">Run Backtest</button>
      <% if (typeof user !== 'undefined' && user && user.settings) { %>
      <button type="button" class="btn btn-outline" onclick="loadLiveSettings()" title="Pre-fill all parameters and feature toggles from your live Performance settings">Load live settings</button>
      <% } %>
    </div>
  </form>
</div>

<!-- Feature Toggles -->
<div class="section" style="margin-bottom:24px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;cursor:pointer;" onclick="document.getElementById('feature-toggles').style.display = document.getElementById('feature-toggles').style.display === 'none' ? 'block' : 'none'; this.querySelector('.toggle-arrow').textContent = document.getElementById('feature-toggles').style.display === 'none' ? '\u25B6' : '\u25BC';">
    <h3 style="color:#e5e7eb;margin:0;">Feature Toggles</h3>
    <span class="toggle-arrow" style="color:#6b7280;font-size:14px;">&#x25BC;</span>
  </div>
  <div id="feature-toggles">
    <p style="color:#6b7280;font-size:12px;margin-bottom:12px;">Toggle individual features on/off to compare performance. All ON = matches live system exactly.</p>

    <!-- Tips & Conflicts -->
    <div style="margin-bottom:16px;padding:14px 16px;background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.35);border-radius:8px;">
      <h4 style="color:#93c5fd;font-size:13px;margin:0 0 10px 0;">Tips &amp; Conflicts</h4>
      <ul style="margin:0;padding-left:18px;color:#9ca3af;font-size:12px;line-height:1.6;">
        <li><strong style="color:#e5e7eb;">Trailing TP mode</strong> ignores Partial TP, Breakeven, and Trailing Stop — the stop trails from entry instead. Use Fixed TPs if you want those features.</li>
        <li><strong style="color:#e5e7eb;">Trailing Stop triggers early?</strong> Increase "Activate at" R (default 1.5×R) or widen "Trail dist" (default 1.5×R) — bigger numbers = wider, less frequent stops.</li>
        <li><strong style="color:#e5e7eb;">DCA + Score Re-check</strong> can conflict: DCA adds to losers when the signal re-confirms, but Score Re-check may exit when the score drops. Prefer DCA OFF if using Score Re-check.</li>
        <li><strong style="color:#e5e7eb;">Quality filters</strong> (Price-Action Confluence, Volatility Filter, Volume Confirmation) stack — using all three reduces trade count but improves quality.</li>
        <li><strong style="color:#e5e7eb;">Recommended defaults:</strong> Session Filter OFF (crypto 24/7) · Min R:R 1.5 · Price-Action Confluence + Volatility Filter ON · Trailing dist 2.0×R · Max Daily Loss 5% · DCA OFF · Score Re-check ON.</li>
      </ul>
    </div>

    <!-- ── 1. SIGNAL & ENTRY QUALITY ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Signal &amp; Entry Quality</h4>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;">
        <label class="ft-toggle" title="Block altcoin LONGs when BTC is STRONG_SELL, block SHORTs when BTC is STRONG_BUY">
          <input type="checkbox" id="ft-btcFilter" checked> <span class="ft-badge ft-signal">SIGNAL</span> BTC Signal Filter
        </label>
        <label class="ft-toggle" title="Penalize score up to -8 when coin is highly correlated with BTC but trading against BTC direction">
          <input type="checkbox" id="ft-btcCorrelation" checked> <span class="ft-badge ft-signal">SIGNAL</span> BTC Correlation Penalty
        </label>
        <label class="ft-toggle" title="Apply session penalty (-5 score) outside 12-22 UTC. OFF recommended — crypto trades 24/7 and Asian session produces many valid moves">
          <input type="checkbox" id="ft-sessionFilter"> <span class="ft-badge ft-signal">SIGNAL</span> Session Filter (12-22 UTC)
        </label>
        <label class="ft-toggle" title="Skip signals with R:R below threshold">
          <input type="checkbox" id="ft-minRiskRewardEnabled" checked onchange="document.getElementById('ft-minRrValue').style.display=this.checked?'flex':'none'"> <span class="ft-badge ft-signal">SIGNAL</span> Min R:R Filter
        </label>
        <div id="ft-minRrValue" style="display:flex;align-items:center;gap:8px;padding-left:4px;">
          <label style="font-size:12px;color:#9ca3af;">Min R:R</label>
          <input type="number" id="ft-minRiskReward" value="1.5" min="1" max="5" step="0.1" style="width:70px;padding:6px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
        <label class="ft-toggle" title="Require at least one of: order block, FVG, or liquidity cluster">
          <input type="checkbox" id="ft-priceActionConfluence" checked> <span class="ft-badge ft-signal">QUALITY</span> Price-Action Confluence (OB/FVG/Liq)
        </label>
        <label class="ft-toggle" title="Skip entries when volatility is extreme (ATR spike > 2× 20-period average)">
          <input type="checkbox" id="ft-volatilityFilter" checked> <span class="ft-badge ft-risk">QUALITY</span> Volatility Filter (skip extreme)
        </label>
        <label class="ft-toggle" title="Require relative volume > 1.0">
          <input type="checkbox" id="ft-volumeConfirmation" checked> <span class="ft-badge ft-signal">QUALITY</span> Volume Confirmation
        </label>
        <label class="ft-toggle" title="Skip LONG when funding >0.15%, skip SHORT when funding <-0.15%">
          <input type="checkbox" id="ft-fundingRateFilter" checked> <span class="ft-badge ft-signal">QUALITY</span> Funding Rate Filter
        </label>
        <label class="ft-toggle" title="Boost/penalize score based on current market themes (trending sectors)">
          <input type="checkbox" id="ft-themeDetector"> <span class="ft-badge ft-signal">THEME</span> Theme Detector
        </label>
      </div>
    </div>

    <!-- ── 2. TAKE-PROFIT MODE ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Take-Profit Mode</h4>
      <div style="display:flex;gap:16px;align-items:center;margin-bottom:12px;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;color:#e5e7eb;font-size:13px;">
          <input type="radio" name="bt-tpMode" value="fixed" checked onchange="document.getElementById('ft-trailingTp').checked=false;document.getElementById('bt-trailing-tp-opts').style.display='none'"> Fixed TPs (TP1/TP2/TP3)
        </label>
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;color:#e5e7eb;font-size:13px;">
          <input type="radio" name="bt-tpMode" value="trailing" onchange="document.getElementById('ft-trailingTp').checked=true;document.getElementById('bt-trailing-tp-opts').style.display='flex'"> Trailing TP (ride the trend)
        </label>
      </div>
      <input type="checkbox" id="ft-trailingTp" style="display:none">
      <div id="bt-trailing-tp-opts" style="display:none;flex-wrap:wrap;gap:12px;padding:12px;background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.2);border-radius:6px;">
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px;">Distance Mode</label>
          <select id="bt-trailingTpDistMode" onchange="document.getElementById('bt-trail-atr').style.display=this.value==='atr'?'block':'none';document.getElementById('bt-trail-fixed').style.display=this.value==='fixed'?'block':'none';" style="padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
            <option value="atr">ATR-based (dynamic)</option>
            <option value="fixed">Fixed % (static)</option>
          </select>
        </div>
        <div id="bt-trail-atr">
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px;">ATR Multiplier</label>
          <input type="number" id="bt-trailingTpAtrMult" value="1.5" min="0.5" max="5" step="0.1" style="width:80px;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
        <div id="bt-trail-fixed" style="display:none;">
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px;">Fixed Trail %</label>
          <input type="number" id="bt-trailingTpFixedPct" value="2" min="0.5" max="10" step="0.1" style="width:80px;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
      </div>
      <div style="margin-top:10px;">
        <label class="ft-toggle" title="TP1 closes 40%, TP2 closes 30%, TP3 closes remaining 30%. OFF = close 100% at TP1">
          <input type="checkbox" id="ft-partialTP" checked> <span class="ft-badge ft-pos">TP</span> Partial Take Profits (40/30/30)
        </label>
      </div>
    </div>

    <!-- ── 3. STOP MANAGEMENT ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Stop Management</h4>
      <div style="display:grid;gap:12px;">

        <!-- Breakeven -->
        <div style="padding:10px 12px;background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.2);border-radius:6px;">
          <label class="ft-toggle" title="Move stop to entry price after reaching beRMult × R profit">
            <input type="checkbox" id="ft-breakeven" checked> <span class="ft-badge ft-pos">BE</span> Breakeven Stop
          </label>
          <div style="display:flex;align-items:center;gap:8px;margin-top:8px;padding-left:4px;flex-wrap:wrap;">
            <span style="font-size:11px;color:#6b7280;">Trigger at</span>
            <input type="number" id="ft-beRMult" value="0.75" min="0.25" max="3" step="0.05" style="width:65px;padding:4px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:5px;color:#e5e7eb;font-size:12px;" title="Move stop to entry when trade is this many R in profit. 0.75 = after 75% of initial risk in profit.">
            <span style="font-size:11px;color:#6b7280;">× R <span style="color:#374151;">(0.75 recommended)</span></span>
          </div>
        </div>

        <!-- Trailing Stop -->
        <div style="padding:10px 12px;background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.2);border-radius:6px;">
          <label class="ft-toggle" title="Trail stop behind best price after reaching trailingStartR × R profit">
            <input type="checkbox" id="ft-trailingStop" checked> <span class="ft-badge ft-pos">TS</span> Trailing Stop Loss
          </label>
          <div style="display:flex;align-items:center;gap:12px;margin-top:8px;padding-left:4px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:6px;">
              <span style="font-size:11px;color:#6b7280;">Activate at</span>
              <input type="number" id="ft-trailingStartR" value="1.5" min="0.5" max="5" step="0.1" style="width:65px;padding:4px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:5px;color:#e5e7eb;font-size:12px;" title="Trailing stop activates when trade reaches this many R in profit">
              <span style="font-size:11px;color:#6b7280;">× R <span style="color:#374151;">(1.5 recommended)</span></span>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <span style="font-size:11px;color:#6b7280;">Trail dist</span>
              <input type="number" id="ft-trailingDistR" value="2.0" min="0.5" max="5" step="0.1" style="width:65px;padding:4px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:5px;color:#e5e7eb;font-size:12px;" title="Stop trails this many R behind the best price. Larger = wider = less likely to be stopped by noise">
              <span style="font-size:11px;color:#6b7280;">× R behind best <span style="color:#374151;">(2.0 recommended)</span></span>
            </div>
          </div>
        </div>

        <!-- Lock-in + SL Cap + Min SL Dist -->
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;">
          <label class="ft-toggle" title="Lock stop at 0.5R/0.75R/1R as trade progresses 50%/75%/90% toward TP2">
            <input type="checkbox" id="ft-lockIn" checked> <span class="ft-badge ft-pos">LOCK</span> Stepped Profit Lock-In
          </label>
          <label class="ft-toggle" title="Cap stop loss distance to max 15% from entry">
            <input type="checkbox" id="ft-slCap" checked> <span class="ft-badge ft-risk">RISK</span> SL Distance Cap (15%)
          </label>
          <label class="ft-toggle" title="Widen stops tighter than 1x ATR to prevent noise-level stop-outs">
            <input type="checkbox" id="ft-minSlDistance" checked> <span class="ft-badge ft-fix">FIX</span> Min SL Distance (1× ATR)
          </label>
          <label class="ft-toggle" title="Re-analyze signal while in trade. Exit on score collapse, reduce 50% on score drop">
            <input type="checkbox" id="ft-scoreRecheck" checked> <span class="ft-badge ft-risk">RISK</span> Score Re-check (Exit/Reduce)
          </label>
        </div>
      </div>
    </div>

    <!-- ── 4. POSITION SIZING ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Position Sizing</h4>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;">
        <label class="ft-toggle" title="Higher score = slightly larger position (0.5 + score/100, cap 1.2×)">
          <input type="checkbox" id="ft-confidenceSizing" checked> <span class="ft-badge ft-cost">SIZE</span> Confidence Sizing
        </label>
        <label class="ft-toggle" title="Blend 70% risk-based + 30% fractional Kelly from strategy win rate & R:R">
          <input type="checkbox" id="ft-kellySizing" checked> <span class="ft-badge ft-cost">SIZE</span> Kelly Criterion Sizing
        </label>
      </div>
    </div>

    <!-- ── 5. RISK CONTROLS ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Risk Controls</h4>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:12px;">
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Max Daily Loss % <span style="color:#374151;">(0=off)</span></label>
          <input type="number" id="ft-maxDailyLoss" value="5" min="0" max="20" step="1" style="width:100%;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;" placeholder="0=off" title="Stop new trades when daily loss exceeds this % of balance. 5% recommended.">
        </div>
        <div>
          <label class="ft-toggle" title="Halve position size when in drawdown" style="margin-bottom:4px;">
            <input type="checkbox" id="ft-drawdownSizing" checked onchange="document.getElementById('ft-drawdownThreshWrap').style.display=this.checked?'block':'none'"> <span class="ft-badge ft-risk">RISK</span> Drawdown Sizing
          </label>
          <div id="ft-drawdownThreshWrap" style="margin-top:6px;">
            <input type="number" id="ft-drawdownThresh" value="10" min="5" max="50" style="width:80px;padding:4px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;"> % threshold
          </div>
        </div>
        <div>
          <label class="ft-toggle" title="Skip coins with 24h volume below this (USD)." style="margin-bottom:4px;">
            <input type="checkbox" id="ft-minVolumeEnabled" onchange="document.getElementById('ft-minVolume').style.display=this.checked?'block':'none'"> <span class="ft-badge ft-signal">QUALITY</span> Min Volume Filter
          </label>
          <input type="number" id="ft-minVolume" value="0" min="0" step="1000000" style="display:none;width:100%;padding:4px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;margin-top:6px;" placeholder="e.g. 50000000">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;">
        <label class="ft-toggle" title="4-bar cooldown before same-direction re-entry (4 bars of primary TF, e.g. 4h for 1h)">
          <input type="checkbox" id="ft-cooldown" checked> <span class="ft-badge ft-risk">RISK</span> Cooldown (4 bars)
        </label>
      </div>
    </div>

    <!-- ── 6. DCA ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">DCA (Dollar Cost Average)</h4>
      <label class="ft-toggle" title="Add to losing positions when signal re-confirms direction and score is above threshold" style="margin-bottom:10px;">
        <input type="checkbox" id="ft-dca" onchange="document.getElementById('bt-dca-opts').style.display=this.checked?'grid':'none'"> <span class="ft-badge ft-pos">DCA</span> Enable DCA
      </label>
      <div id="bt-dca-opts" style="display:none;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;">
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Max Adds</label>
          <input type="number" id="bt-dcaMaxAdds" value="3" min="1" max="10" step="1" style="width:100%;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Dip % per Level</label>
          <input type="number" id="bt-dcaDipPct" value="2" min="0.5" max="20" step="0.5" style="width:100%;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Add Size (% of original)</label>
          <input type="number" id="bt-dcaAddSizePct" value="100" min="25" max="200" step="25" style="width:100%;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
        <div>
          <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Min Score to Re-confirm</label>
          <input type="number" id="bt-dcaMinScore" value="52" min="30" max="95" step="1" style="width:100%;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:12px;">
        </div>
      </div>
    </div>

    <!-- ── 7. COSTS & REALISM ── -->
    <div style="margin-bottom:16px;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;">
      <h4 style="color:#e5e7eb;margin:0 0 12px 0;font-size:14px;">Costs &amp; Realism</h4>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;">
        <label class="ft-toggle" title="0.1% taker fee on entry and exit">
          <input type="checkbox" id="ft-fees" checked> <span class="ft-badge ft-cost">COST</span> Trading Fees (0.1%)
        </label>
        <label class="ft-toggle" title="0.05% slippage simulation on entry and exit">
          <input type="checkbox" id="ft-slippage" checked> <span class="ft-badge ft-cost">COST</span> Slippage (0.05%)
        </label>
        <label class="ft-toggle" title="1.5× slippage stress test — strategies that survive are more robust">
          <input type="checkbox" id="ft-slippageStress"> <span class="ft-badge ft-risk">STRESS</span> Stress Test (1.5× slippage)
        </label>
        <label class="ft-toggle" title="Use bar close for SL check (matches live system). OFF = use candle wicks">
          <input type="checkbox" id="ft-closeBasedStops" checked> <span class="ft-badge ft-fix">FIX</span> Close-Based Stops (realistic)
        </label>
      </div>
    </div>

    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
      <button type="button" class="btn btn-sm" onclick="setAllToggles(true)" style="padding:4px 12px;font-size:11px;background:#1e2a3a;border:1px solid #334155;color:#e5e7eb;border-radius:4px;cursor:pointer;">All ON</button>
      <button type="button" class="btn btn-sm" onclick="setAllToggles(false)" style="padding:4px 12px;font-size:11px;background:#1e2a3a;border:1px solid #334155;color:#e5e7eb;border-radius:4px;cursor:pointer;">All OFF</button>
      <button type="button" class="btn btn-sm" onclick="setPresetsMinimal()" style="padding:4px 12px;font-size:11px;background:#1e2a3a;border:1px solid #334155;color:#e5e7eb;border-radius:4px;cursor:pointer;">Minimal (raw signals only)</button>
      <button type="button" class="btn btn-sm" onclick="saveAsLivePreset()" style="padding:4px 12px;font-size:11px;background:#1e2a3a;border:1px solid #10b981;color:#10b981;border-radius:4px;cursor:pointer;" title="Save current toggle configuration for use on the Performance page">Save as Live Preset</button>
      <span style="font-size:11px;color:#6b7280;">Preset:</span>
      <select id="bt-preset-select" onchange="loadBacktestPresetByName(this.value)" style="padding:4px 10px;background:#0d1320;border:1px solid #334155;border-radius:6px;color:#e5e7eb;font-size:12px;min-width:120px;">
        <option value="">— Load —</option>
      </select>
      <button type="button" class="btn btn-sm" onclick="var n=prompt('Preset name');if(n)saveBacktestPreset(n)" style="padding:4px 12px;font-size:11px;background:#1e2a3a;border:1px solid #3b82f6;color:#3b82f6;border-radius:4px;cursor:pointer;">Save Preset</button>
    </div>
  </div>
</div>

<!-- Loading -->
<div id="backtest-loading" class="section" style="display:none;text-align:center;padding:40px;">
  <div style="font-size:32px;margin-bottom:12px;animation:pulse 1.5s infinite;">&#x23F3;</div>
  <p id="bt-progress-text" style="color:#9ca3af;">Starting backtest...</p>
  <p id="bt-elapsed-text" style="color:#6b7280;font-size:13px;margin-top:4px;"></p>
</div>

<!-- Error banner (shown instead of cryptic JSON parse errors) -->
<div id="bt-error-banner" style="display:none;margin-bottom:16px;padding:14px 18px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.35);border-radius:10px;color:#f87171;font-size:14px;line-height:1.5;"></div>

<!-- Results -->
<div id="backtest-results" style="display:none;">
  <!-- Diagnostic message when empty -->
  <div id="backtest-diagnostic" class="section" style="display:none;margin-bottom:24px;padding:16px;background:rgba(234,179,8,0.1);border:1px solid rgba(234,179,8,0.3);border-radius:8px;">
    <p id="backtest-diagnostic-msg" style="color:#eab308;margin:0;font-size:14px;"></p>
  </div>
  <!-- Summary -->
  <div class="section" style="margin-bottom:24px;">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
      <h3 style="color:#e5e7eb;margin:0;">Summary</h3>
      <span id="bt-config-used" style="font-size:12px;color:#6b7280;"></span>
    </div>
    <div class="perf-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;">
      <div class="perf-card">
        <div class="perf-label">Total Trades</div>
        <div class="perf-value" id="bt-trades">0</div>
      </div>
      <div class="perf-card">
        <div class="perf-label">Win Rate</div>
        <div class="perf-value" id="bt-winrate">0%</div>
      </div>
      <div class="perf-card">
        <div class="perf-label">Total PnL</div>
        <div class="perf-value" id="bt-pnl">$0</div>
      </div>
      <div class="perf-card" title="Return % = (total PnL / initial balance) × 100">
        <div class="perf-label">Return %</div>
        <div class="perf-value" id="bt-return">0%</div>
      </div>
      <div class="perf-card">
        <div class="perf-label">Profit Factor</div>
        <div class="perf-value" id="bt-pf">0</div>
      </div>
      <div class="perf-card">
        <div class="perf-label">Max Drawdown</div>
        <div class="perf-value down" id="bt-dd">0%</div>
      </div>
    </div>
  </div>

  <!-- Equity Curve Chart -->
  <div class="section" style="margin-bottom:24px;" id="bt-equity-section">
    <h3 style="color:#e5e7eb;margin-bottom:12px;">Equity Curve</h3>
    <div id="bt-equity-chart" style="height:200px;background:rgba(15,23,42,0.6);border:1px solid #334155;border-radius:8px;padding:12px;">
      <div id="bt-equity-bars" style="display:flex;align-items:flex-end;gap:2px;height:160px;overflow-x:auto;"></div>
      <div id="bt-equity-legend" style="font-size:11px;color:#6b7280;margin-top:8px;"></div>
    </div>
  </div>

  <!-- Regime Breakdown -->
  <div class="section" style="margin-bottom:24px;" id="bt-regime-section">
    <h3 style="color:#e5e7eb;margin-bottom:12px;">Regime Breakdown</h3>
    <div id="bt-regime-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;"></div>
  </div>

  <!-- Action Badges & Exit Reasons -->
  <div class="section" style="margin-bottom:24px;" id="bt-actions-section" style="display:none;">
    <h3 style="color:#e5e7eb;margin-bottom:12px;">Actions Taken & Exit Reasons</h3>
    <div style="display:flex;flex-wrap:wrap;gap:16px;">
      <div style="flex:1;min-width:200px;">
        <div style="color:#6b7280;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Action Badges</div>
        <div id="bt-action-badges" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>
      <div style="flex:1;min-width:200px;">
        <div style="color:#6b7280;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Exit Reasons</div>
        <div id="bt-exit-reasons" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>
    </div>
  </div>

  <!-- Per-coin results -->
  <div class="section" style="margin-bottom:24px;">
    <h3 style="color:#e5e7eb;margin-bottom:12px;">Per-Coin Results</h3>
    <div class="per-coin-wrap" style="overflow-x:auto;width:100%;">
      <table class="data-table" id="bt-coins-table">
        <thead>
          <tr>
            <th>Coin</th>
            <th>Trades</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Win Rate</th>
            <th>PnL</th>
            <th>Return %</th>
            <th>Max DD %</th>
          </tr>
        </thead>
        <tbody id="bt-coins-body"></tbody>
      </table>
    </div>
  </div>

  <!-- Trade list -->
  <div class="section" style="margin-bottom:24px;">
    <h3 style="color:#e5e7eb;margin-bottom:12px;">Trade List</h3>
    <div class="trade-list-wrap" style="overflow-x:auto;max-height:400px;overflow-y:auto;width:100%;">
      <table class="data-table" id="bt-trades-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Coin</th>
            <th>Dir</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>Reason</th>
            <th>Actions</th>
            <th>PnL</th>
          </tr>
        </thead>
        <tbody id="bt-trades-body"></tbody>
      </table>
    </div>
  </div>
</div>

<script>
// Feature toggle helpers
function setAllToggles(val) {
  document.querySelectorAll('#feature-toggles input[type=checkbox]').forEach(function(cb) { cb.checked = val; });
  var trailOpts = document.getElementById('bt-trailing-tp-opts');
  var dcaOpts = document.getElementById('bt-dca-opts');
  if (trailOpts) trailOpts.style.display = val ? 'flex' : 'none';
  if (dcaOpts) dcaOpts.style.display = val ? 'flex' : 'none';
}
function setPresetsMinimal() {
  setAllToggles(false);
  // Keep realism fixes ON even in minimal mode
  document.getElementById('ft-slippage').checked = true;
  document.getElementById('ft-closeBasedStops').checked = true;
  document.getElementById('ft-minSlDistance').checked = true;
}
function getFeatureFlags() {
  var flags = {
    btcFilter: document.getElementById('ft-btcFilter').checked,
    btcCorrelation: document.getElementById('ft-btcCorrelation').checked,
    sessionFilter: document.getElementById('ft-sessionFilter').checked,
    partialTP: document.getElementById('ft-partialTP').checked,
    breakeven: document.getElementById('ft-breakeven').checked,
    breakevenRMult: parseFloat(document.getElementById('ft-beRMult')?.value) || 0.75,
    trailingStop: document.getElementById('ft-trailingStop').checked,
    trailingStartR: parseFloat(document.getElementById('ft-trailingStartR')?.value) || 1.5,
    trailingDistR: parseFloat(document.getElementById('ft-trailingDistR')?.value) || 2.0,
    lockIn: document.getElementById('ft-lockIn').checked,
    scoreRecheck: document.getElementById('ft-scoreRecheck').checked,
    slCap: document.getElementById('ft-slCap').checked,
    cooldown: document.getElementById('ft-cooldown').checked,
    confidenceSizing: document.getElementById('ft-confidenceSizing').checked,
    kellySizing: document.getElementById('ft-kellySizing').checked,
    priceActionConfluence: document.getElementById('ft-priceActionConfluence').checked,
    volatilityFilter: document.getElementById('ft-volatilityFilter').checked,
    volumeConfirmation: document.getElementById('ft-volumeConfirmation').checked,
    fundingRateFilter: document.getElementById('ft-fundingRateFilter')?.checked || false,
    themeDetector: document.getElementById('ft-themeDetector')?.checked || false,
    minRiskRewardEnabled: document.getElementById('ft-minRiskRewardEnabled').checked,
    minRiskReward: parseFloat(document.getElementById('ft-minRiskReward').value) || 1.5,
    maxDailyLossPercent: parseFloat(document.getElementById('ft-maxDailyLoss')?.value) || 0,
    minVolume24hUsd: (document.getElementById('ft-minVolumeEnabled')?.checked ? parseFloat(document.getElementById('ft-minVolume')?.value) : 0) || 0,
    drawdownSizingEnabled: document.getElementById('ft-drawdownSizing')?.checked || false,
    drawdownThresholdPercent: parseFloat(document.getElementById('ft-drawdownThresh')?.value) || 10,
    fees: document.getElementById('ft-fees').checked,
    slippage: document.getElementById('ft-slippage').checked,
    slippageMultiplier: document.getElementById('ft-slippageStress').checked ? 1.5 : 1,
    closeBasedStops: document.getElementById('ft-closeBasedStops').checked,
    minSlDistance: document.getElementById('ft-minSlDistance').checked,
    trailingTp: document.getElementById('ft-trailingTp').checked,
    dca: document.getElementById('ft-dca').checked
  };
  if (flags.trailingTp) {
    flags.trailingTpDistanceMode = document.getElementById('bt-trailingTpDistMode').value;
    flags.trailingTpAtrMultiplier = parseFloat(document.getElementById('bt-trailingTpAtrMult').value) || 1.5;
    flags.trailingTpFixedPercent = parseFloat(document.getElementById('bt-trailingTpFixedPct').value) || 2;
  }
  if (flags.dca) {
    flags.dcaMaxAdds = parseInt(document.getElementById('bt-dcaMaxAdds').value, 10) || 3;
    flags.dcaDipPercent = parseFloat(document.getElementById('bt-dcaDipPct').value) || 2;
    flags.dcaAddSizePercent = parseFloat(document.getElementById('bt-dcaAddSizePct').value) || 100;
    flags.dcaMinScore = parseInt(document.getElementById('bt-dcaMinScore').value, 10) || 52;
  }
  return flags;
}

// Save current toggle config to localStorage for transfer to Performance page
function saveAsLivePreset() {
  var flags = getFeatureFlags();
  localStorage.setItem('backtestFeaturePreset', JSON.stringify(flags));
  alert('Toggle preset saved! Go to Performance page and click "Load from Backtest" to apply.');
}

// Save named backtest preset
function saveBacktestPreset(name) {
  if (!name || !name.trim()) return;
  var flags = getFeatureFlags();
  var presets = JSON.parse(localStorage.getItem('backtestPresets') || '{}');
  presets[name.trim()] = { flags: flags, savedAt: new Date().toISOString() };
  localStorage.setItem('backtestPresets', JSON.stringify(presets));
  alert('Preset "' + name + '" saved.');
  populatePresetSelect();
}

// Load backtest preset by name
function loadBacktestPresetByName(name) {
  if (!name) return;
  var presets = JSON.parse(localStorage.getItem('backtestPresets') || '{}');
  var p = presets[name];
  if (!p || !p.flags) { alert('Preset not found'); return; }
  var f = p.flags;
  document.getElementById('ft-btcFilter').checked = f.btcFilter;
  document.getElementById('ft-btcCorrelation').checked = f.btcCorrelation;
  document.getElementById('ft-sessionFilter').checked = f.sessionFilter;
  document.getElementById('ft-partialTP').checked = f.partialTP;
  document.getElementById('ft-breakeven').checked = f.breakeven;
  document.getElementById('ft-trailingStop').checked = f.trailingStop;
  document.getElementById('ft-lockIn').checked = f.lockIn;
  document.getElementById('ft-scoreRecheck').checked = f.scoreRecheck;
  document.getElementById('ft-slCap').checked = f.slCap;
  document.getElementById('ft-cooldown').checked = f.cooldown;
  document.getElementById('ft-confidenceSizing').checked = f.confidenceSizing;
  if (document.getElementById('ft-kellySizing')) document.getElementById('ft-kellySizing').checked = f.kellySizing !== false;
  document.getElementById('ft-priceActionConfluence').checked = f.priceActionConfluence;
  document.getElementById('ft-volatilityFilter').checked = f.volatilityFilter;
  document.getElementById('ft-volumeConfirmation').checked = f.volumeConfirmation;
  if (document.getElementById('ft-fundingRateFilter')) document.getElementById('ft-fundingRateFilter').checked = f.fundingRateFilter;
  document.getElementById('ft-minRiskRewardEnabled').checked = f.minRiskRewardEnabled;
  document.getElementById('ft-minRiskReward').value = f.minRiskReward || 1.5;
  if (document.getElementById('ft-maxDailyLoss')) document.getElementById('ft-maxDailyLoss').value = f.maxDailyLossPercent || 0;
  document.getElementById('ft-drawdownSizing').checked = f.drawdownSizingEnabled;
  document.getElementById('ft-drawdownThresh').value = f.drawdownThresholdPercent || 10;
  document.getElementById('ft-fees').checked = f.fees;
  document.getElementById('ft-slippage').checked = f.slippage;
  if (document.getElementById('ft-slippageStress')) document.getElementById('ft-slippageStress').checked = f.slippageMultiplier === 1.5;
  document.getElementById('ft-closeBasedStops').checked = f.closeBasedStops;
  document.getElementById('ft-minSlDistance').checked = f.minSlDistance;
  document.getElementById('ft-trailingTp').checked = f.trailingTp;
  document.querySelectorAll('input[name="bt-tpMode"]').forEach(function(r) { r.checked = r.value === (f.trailingTp ? 'trailing' : 'fixed'); });
  document.getElementById('ft-dca').checked = f.dca;
  document.getElementById('bt-trailing-tp-opts').style.display = f.trailingTp ? 'flex' : 'none';
  document.getElementById('bt-dca-opts').style.display = f.dca ? 'grid' : 'none';
  // Stop management
  if (f.breakevenRMult != null) { var beEl = document.getElementById('ft-beRMult'); if (beEl) beEl.value = f.breakevenRMult; }
  if (f.trailingStartR != null) { var tsEl = document.getElementById('ft-trailingStartR'); if (tsEl) tsEl.value = f.trailingStartR; }
  if (f.trailingDistR != null) { var tdEl = document.getElementById('ft-trailingDistR'); if (tdEl) tdEl.value = f.trailingDistR; }
  if (document.getElementById('ft-themeDetector')) document.getElementById('ft-themeDetector').checked = !!f.themeDetector;
  // Min volume filter
  var minVolEl = document.getElementById('ft-minVolumeEnabled');
  var minVolVal = document.getElementById('ft-minVolume');
  if (minVolEl && minVolVal) {
    minVolEl.checked = !!(f.minVolume24hUsd && f.minVolume24hUsd > 0);
    minVolVal.value = f.minVolume24hUsd || 0;
    document.getElementById('ft-minVolume').style.display = minVolEl.checked ? 'block' : 'none';
  }
  // Trailing TP opts
  if (f.trailingTp) {
    var distMode = document.getElementById('bt-trailingTpDistMode');
    if (distMode) distMode.value = f.trailingTpDistanceMode || 'atr';
    var atrMult = document.getElementById('bt-trailingTpAtrMult');
    if (atrMult) atrMult.value = f.trailingTpAtrMultiplier ?? 1.5;
    var fixedPct = document.getElementById('bt-trailingTpFixedPct');
    if (fixedPct) fixedPct.value = f.trailingTpFixedPercent ?? 2;
    document.getElementById('bt-trail-atr').style.display = (f.trailingTpDistanceMode || 'atr') === 'atr' ? 'block' : 'none';
    document.getElementById('bt-trail-fixed').style.display = (f.trailingTpDistanceMode || 'atr') === 'fixed' ? 'block' : 'none';
  }
  if (f.dca) {
    var dcaMax = document.getElementById('bt-dcaMaxAdds');
    if (dcaMax) dcaMax.value = f.dcaMaxAdds ?? 3;
    var dcaDip = document.getElementById('bt-dcaDipPct');
    if (dcaDip) dcaDip.value = f.dcaDipPercent ?? 2;
    var dcaSize = document.getElementById('bt-dcaAddSizePct');
    if (dcaSize) dcaSize.value = f.dcaAddSizePercent ?? 100;
    var dcaScore = document.getElementById('bt-dcaMinScore');
    if (dcaScore) dcaScore.value = f.dcaMinScore ?? 52;
  }
}

function populatePresetSelect() {
  var sel = document.getElementById('bt-preset-select');
  if (!sel) return;
  var presets = JSON.parse(localStorage.getItem('backtestPresets') || '{}');
  var names = Object.keys(presets).sort();
  sel.innerHTML = '<option value="">— Load —</option>';
  names.forEach(function(n) { sel.innerHTML += '<option value="' + n + '">' + n + '</option>'; });
}

// Badge rendering
var ACTION_BADGE_MAP = {
  BE: { label: 'BE', color: '#3b82f6', desc: 'Breakeven' },
  TS: { label: 'TS', color: '#8b5cf6', desc: 'Trailing Stop' },
  PP: { label: 'PP', color: '#10b981', desc: 'Partial Profit' },
  RP: { label: 'RP', color: '#f59e0b', desc: 'Reduce Position' },
  DCA: { label: 'DCA', color: '#06b6d4', desc: 'Dollar Cost Average' },
  EXIT: { label: 'EXIT', color: '#ef4444', desc: 'Score Exit' },
  LOCK: { label: 'LOCK', color: '#06b6d4', desc: 'Profit Lock-In' }
};
var EXIT_REASON_MAP = {
  SL: { label: 'SL', color: '#ef4444' },
  TRAILING_TP_EXIT: { label: 'Trail Exit', color: '#8b5cf6' },
  TP: { label: 'TP', color: '#10b981' },
  TP1: { label: 'TP1', color: '#10b981' },
  TP2: { label: 'TP2', color: '#10b981' },
  TP3: { label: 'TP3', color: '#10b981' },
  SCORE_EXIT: { label: 'Score Exit', color: '#f59e0b' },
  END: { label: 'End', color: '#6b7280' }
};
function renderBadge(type, count, map) {
  var info = map[type] || { label: type, color: '#6b7280' };
  return '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:600;background:' + info.color + '22;color:' + info.color + ';border:1px solid ' + info.color + '44;">' +
    info.label + ' <span style="font-weight:400;opacity:0.8;">' + count + '</span></span>';
}
function renderActionBadgesForTrade(actions) {
  if (!actions || actions.length === 0) return '<span style="color:#374151;font-size:11px;">-</span>';
  var types = {};
  actions.forEach(function(a) { types[a.type] = (types[a.type] || 0) + 1; });
  return Object.keys(types).map(function(t) {
    var info = ACTION_BADGE_MAP[t] || { label: t, color: '#6b7280' };
    return '<span style="padding:1px 5px;border-radius:3px;font-size:10px;font-weight:600;background:' + info.color + '22;color:' + info.color + ';">' + info.label + '</span>';
  }).join(' ');
}

// Inject live settings from server (only when logged in)
<% if (typeof user !== 'undefined' && user && user.settings) { %>
var LIVE_SETTINGS = <%- JSON.stringify(user.settings) %>;
<% } else { %>
var LIVE_SETTINGS = null;
<% } %>

function loadLiveSettings() {
  if (!LIVE_SETTINGS) { alert('Log in to load your live settings.'); return; }
  var s = LIVE_SETTINGS;

  // Core parameters
  if (s.autoTradeMinScore != null) document.getElementById('minScore').value = s.autoTradeMinScore;
  if (s.defaultLeverage != null) document.getElementById('leverage').value = s.defaultLeverage;
  if (s.riskMode) {
    document.getElementById('riskMode').value = s.riskMode;
    document.getElementById('bt-risk-pct-wrap').style.display = s.riskMode === 'dollar' ? 'none' : '';
    document.getElementById('bt-risk-dollar-wrap').style.display = s.riskMode === 'dollar' ? '' : 'none';
  }
  if (s.riskPerTrade != null) document.getElementById('riskPerTrade').value = s.riskPerTrade;
  if (s.riskDollarsPerTrade != null) document.getElementById('riskDollarsPerTrade').value = s.riskDollarsPerTrade;

  // Feature toggles
  var set = function(id, val) { var el = document.getElementById(id); if (el) el.checked = !!val; };
  set('ft-btcFilter',            s.featureBtcFilter !== false);
  set('ft-btcCorrelation',       s.featureBtcCorrelation !== false);
  set('ft-sessionFilter',        s.featureSessionFilter !== false);
  set('ft-partialTP',            s.featurePartialTP !== false);
  set('ft-breakeven',            s.autoMoveBreakeven !== false);
  if (s.breakevenRMult != null) { var beEl = document.getElementById('ft-beRMult'); if (beEl) beEl.value = s.breakevenRMult; }
  set('ft-trailingStop',         s.autoTrailingStop !== false);
  if (s.trailingStartR != null) { var tsEl = document.getElementById('ft-trailingStartR'); if (tsEl) tsEl.value = s.trailingStartR; }
  if (s.trailingDistR != null) { var tdEl = document.getElementById('ft-trailingDistR'); if (tdEl) tdEl.value = s.trailingDistR; }
  set('ft-lockIn',               s.featureLockIn !== false);
  set('ft-scoreRecheck',         s.featureScoreRecheck !== false);
  set('ft-slCap',                s.featureSlCap !== false);
  set('ft-minSlDistance',        s.featureMinSlDistance !== false);
  set('ft-priceActionConfluence',s.featurePriceActionConfluence === true);
  set('ft-volatilityFilter',     s.featureVolatilityFilter === true);
  set('ft-volumeConfirmation',   s.featureVolumeConfirmation !== false);
  set('ft-fundingRateFilter',    s.featureFundingRateFilter !== false);
  set('ft-themeDetector',        s.featureThemeDetector === true);
  set('ft-cooldown',             (s.cooldownHours != null ? s.cooldownHours : 6) > 0);
  set('ft-minRiskRewardEnabled', s.minRiskRewardEnabled !== false);
  if (s.minRiskReward != null) { var rr = document.getElementById('ft-minRiskReward'); if (rr) rr.value = s.minRiskReward; }
  var rrWrap = document.getElementById('ft-minRrValue'); if (rrWrap) rrWrap.style.display = s.minRiskRewardEnabled !== false ? 'flex' : 'none';

  // Trailing TP — sync radio buttons and hidden checkbox
  var trailingTp = s.tpMode === 'trailing';
  set('ft-trailingTp', trailingTp);
  document.querySelectorAll('input[name="bt-tpMode"]').forEach(function(r) { r.checked = r.value === (trailingTp ? 'trailing' : 'fixed'); });
  var trailingOpts = document.getElementById('bt-trailing-tp-opts'); if (trailingOpts) trailingOpts.style.display = trailingTp ? 'flex' : 'none';
  if (s.trailingTpDistanceMode) { var tm = document.getElementById('bt-trailingTpDistMode'); if (tm) tm.value = s.trailingTpDistanceMode; }
  if (s.trailingTpAtrMultiplier != null) { var ta = document.getElementById('bt-trailingTpAtrMult'); if (ta) ta.value = s.trailingTpAtrMultiplier; }
  if (s.trailingTpFixedPercent != null) { var tf = document.getElementById('bt-trailingTpFixedPct'); if (tf) tf.value = s.trailingTpFixedPercent; }

  // DCA
  set('ft-dca', s.dcaEnabled === true);
  var dcaOpts = document.getElementById('bt-dca-opts'); if (dcaOpts) dcaOpts.style.display = s.dcaEnabled ? 'flex' : 'none';
  if (s.dcaMaxAdds != null) { var da = document.getElementById('bt-dcaMaxAdds'); if (da) da.value = s.dcaMaxAdds; }
  if (s.dcaDipPercent != null) { var dd = document.getElementById('bt-dcaDipPct'); if (dd) dd.value = s.dcaDipPercent; }
  if (s.dcaAddSizePercent != null) { var ds = document.getElementById('bt-dcaAddSizePct'); if (ds) ds.value = s.dcaAddSizePercent; }
  if (s.dcaMinScore != null) { var dm = document.getElementById('bt-dcaMinScore'); if (dm) dm.value = s.dcaMinScore; }

  // Show confirmation
  var btn = document.querySelector('button[onclick="loadLiveSettings()"]');
  if (btn) { btn.textContent = '✓ Loaded'; btn.style.color = '#10b981'; setTimeout(function() { btn.textContent = 'Load live settings'; btn.style.color = ''; }, 2000); }
}

(function() {
  var form = document.getElementById('backtest-form');
  var loading = document.getElementById('backtest-loading');
  var results = document.getElementById('backtest-results');
  var runBtn = document.getElementById('run-btn');

  populatePresetSelect();

  document.getElementById('btMode').addEventListener('change', function() {
    var v = this.value;
    document.getElementById('bt-walkforward-opts').style.display = v === 'walkforward' ? 'block' : 'none';
    document.getElementById('bt-sweep-opts').style.display = v === 'sweep' ? 'block' : 'none';
  });

  // Default dates: last 90 days (3 months → 200+ trades with multi-coin)
  var end = new Date();
  var start = new Date();
  start.setDate(start.getDate() - 90);
  document.getElementById('endDate').value = end.toISOString().slice(0, 10);
  document.getElementById('startDate').value = start.toISOString().slice(0, 10);

  // Date presets: 6 months, 1 year (1yr+ supported; 1h/4h TF recommended for speed)
  var preset6m = document.getElementById('bt-preset-6m');
  var preset1y = document.getElementById('bt-preset-1y');
  if (preset6m) preset6m.addEventListener('click', function() { var s = new Date(); s.setMonth(s.getMonth() - 6); document.getElementById('startDate').value = s.toISOString().slice(0, 10); });
  if (preset1y) preset1y.addEventListener('click', function() { var s = new Date(); s.setFullYear(s.getFullYear() - 1); document.getElementById('startDate').value = s.toISOString().slice(0, 10); });

  // Risk mode toggle: show % or $ input
  document.getElementById('riskMode').addEventListener('change', function() {
    var isDollar = this.value === 'dollar';
    document.getElementById('bt-risk-pct-wrap').style.display = isDollar ? 'none' : '';
    document.getElementById('bt-risk-dollar-wrap').style.display = isDollar ? '' : 'none';
  });

  function updateProgress(msg, elapsed) {
    var el = document.getElementById('bt-progress-text');
    var elapsedEl = document.getElementById('bt-elapsed-text');
    if (el) el.textContent = msg || 'Running backtest...';
    if (elapsedEl) elapsedEl.textContent = elapsed != null ? ('Elapsed: ' + elapsed + 's') : '';
  }

  async function pollBacktestJob(jobId, maxWaitMs) {
    maxWaitMs = maxWaitMs || 600000; // 10 min max
    var start = Date.now();
    var pollInterval = 2000;
    while (Date.now() - start < maxWaitMs) {
      await new Promise(function(r) { setTimeout(r, pollInterval); });
      if (pollInterval < 5000) pollInterval += 500;
      var res;
      try {
        res = await fetch('/api/backtest/status/' + jobId, { credentials: 'same-origin' });
      } catch (e) {
        updateProgress('Connection lost, retrying...');
        continue;
      }
      if (res.status === 404) throw new Error('Backtest job expired or not found. Please try again.');
      var ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) continue;
      var data = await res.json();
      if (data.status === 'running') {
        updateProgress(data.progress || 'Processing...', data.elapsed);
        continue;
      }
      if (data.error) throw new Error(data.error);
      return data;
    }
    throw new Error('Backtest timed out after ' + Math.round(maxWaitMs / 60000) + ' minutes. Try fewer coins or a shorter date range.');
  }

  async function runOneBacktest(b) {
    updateProgress('Submitting backtest job...');
    var res;
    try {
      res = await fetch('/api/backtest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(b),
        credentials: 'same-origin'
      });
    } catch (fetchErr) {
      throw new Error('Network error: ' + fetchErr.message);
    }
    var contentType = res.headers.get('content-type') || '';
    if (!contentType.includes('application/json')) {
      throw new Error('Server returned an unexpected response (' + res.status + '). Please try again.');
    }
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Backtest failed');

    if (data.jobId) {
      updateProgress('Backtest started for ' + (data.coins || []).length + ' coin(s)... fetching candles & simulating trades');
      return await pollBacktestJob(data.jobId);
    }
    return data;
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    runBtn.disabled = true;
    loading.style.display = 'block';
    results.style.display = 'none';
    var errBanner = document.getElementById('bt-error-banner');
    if (errBanner) errBanner.style.display = 'none';

    var coinId = document.getElementById('coinId').value;
    var riskMode = document.getElementById('riskMode').value;
    var mode = document.getElementById('btMode').value;
    var baseBody = {
      startDate: document.getElementById('startDate').value,
      endDate: document.getElementById('endDate').value,
      primaryTf: document.getElementById('primaryTf').value || '1h',
      minScore: parseInt(document.getElementById('minScore').value, 10) || 52,
      leverage: parseInt(document.getElementById('leverage').value, 10) || 2,
      initialBalance: parseInt(document.getElementById('initialBalance').value, 10) || 10000,
      riskMode: riskMode,
      riskPerTrade: parseFloat(document.getElementById('riskPerTrade').value) || 2,
      riskDollarsPerTrade: parseInt(document.getElementById('riskDollarsPerTrade').value, 10) || 200,
      features: getFeatureFlags()
    };
    if (coinId) baseBody.coinId = coinId;

    var data;
    try {
      if (mode === 'walkforward') {
        var trainPct = parseInt(document.getElementById('btTrainPct').value, 10) || 70;
        var start = new Date(baseBody.startDate).getTime();
        var end = new Date(baseBody.endDate).getTime();
        var span = end - start;
        var trainEnd = start + (span * trainPct / 100);
        var trainBody = Object.assign({}, baseBody, { startDate: new Date(start).toISOString().slice(0,10), endDate: new Date(trainEnd).toISOString().slice(0,10) });
        var testBody = Object.assign({}, baseBody, { startDate: new Date(trainEnd).toISOString().slice(0,10), endDate: baseBody.endDate });
        var trainData = await runOneBacktest(trainBody);

        // Apply training to weights before running test phase
        var applyTrainingEl = document.getElementById('btApplyTraining');
        var applyStatusEl = document.getElementById('bt-apply-training-status');
        if (applyTrainingEl && applyTrainingEl.checked && trainData.allTrades && trainData.allTrades.length > 0) {
          applyStatusEl.style.display = 'block';
          applyStatusEl.style.background = 'rgba(59,130,246,0.12)';
          applyStatusEl.style.color = '#93c5fd';
          applyStatusEl.textContent = 'Applying training results to strategy weights...';
          try {
            var applyRes = await fetch('/api/backtest/apply-training', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ allTrades: trainData.allTrades }),
              credentials: 'same-origin'
            });
            var applyData = await applyRes.json();
            if (applyData.success) {
              // Build a readable summary of what changed
              var regimeSummary = (applyData.summary || []).map(function(s) {
                var wr = s.totalWins + s.totalLosses > 0 ? Math.round(s.totalWins / (s.totalWins + s.totalLosses) * 100) : 0;
                return s.regime + ' ' + wr + '%WR';
              }).join(', ');
              applyStatusEl.style.background = 'rgba(16,185,129,0.12)';
              applyStatusEl.style.color = '#10b981';
              applyStatusEl.textContent = '✓ Updated ' + applyData.updated + ' strategy+regime combos' + (regimeSummary ? ' (' + regimeSummary + ')' : '') + '. Live system will now favour/avoid these regimes.';
            } else {
              applyStatusEl.style.background = 'rgba(239,68,68,0.12)';
              applyStatusEl.style.color = '#ef4444';
              applyStatusEl.textContent = 'Could not apply training: ' + (applyData.error || 'unknown error');
            }
          } catch (applyErr) {
            applyStatusEl.style.background = 'rgba(239,68,68,0.12)';
            applyStatusEl.style.color = '#ef4444';
            applyStatusEl.textContent = 'Apply training failed: ' + applyErr.message;
          }
        } else if (applyStatusEl) {
          applyStatusEl.style.display = 'none';
        }

        var testData = await runOneBacktest(testBody);
        data = {
          summary: {
            totalTrades: (trainData.summary?.totalTrades || 0) + (testData.summary?.totalTrades || 0),
            wins: (trainData.summary?.wins || 0) + (testData.summary?.wins || 0),
            losses: (trainData.summary?.losses || 0) + (testData.summary?.losses || 0),
            totalPnl: (trainData.summary?.totalPnl || 0) + (testData.summary?.totalPnl || 0),
            returnPct: ((trainData.summary?.totalPnl || 0) + (testData.summary?.totalPnl || 0)) / (baseBody.initialBalance || 10000) * 100,
            profitFactor: trainData.summary?.profitFactor,
            coinsProcessed: trainData.summary?.coinsProcessed,
            coinsFailed: trainData.summary?.coinsFailed,
            totalBars: (trainData.summary?.totalBars || 0) + (testData.summary?.totalBars || 0)
          },
          results: testData.results,
          failed: testData.failed,
          equityCurve: testData.equityCurve,
          regimeBreakdown: testData.regimeBreakdown,
          allTrades: (testData.allTrades || []),
          walkForward: { train: trainData.summary, test: testData.summary }
        };
        data.summary.winRate = data.summary.totalTrades > 0 ? (data.summary.wins / data.summary.totalTrades) * 100 : 0;
      } else if (mode === 'sweep') {
        var sweepVals = (document.getElementById('btSweepMinScore').value || '48,52,56').split(',').map(function(x) { return parseInt(x.trim(), 10); }).filter(function(x) { return !isNaN(x); });
        if (sweepVals.length === 0) sweepVals = [52];
        var sweepResults = [];
        for (var i = 0; i < sweepVals.length; i++) {
          var b = Object.assign({}, baseBody, { minScore: sweepVals[i] });
          var d = await runOneBacktest(b);
          sweepResults.push({ minScore: sweepVals[i], summary: d.summary });
        }
        var best = sweepResults.sort(function(a, b) { return (b.summary?.totalPnl || 0) - (a.summary?.totalPnl || 0); })[0];
        data = {
          summary: best ? best.summary : { totalTrades: 0, wins: 0, losses: 0, totalPnl: 0, returnPct: 0, profitFactor: 0, winRate: 0, coinsProcessed: 0, coinsFailed: 0, totalBars: 0 },
          results: [],
          failed: [],
          equityCurve: [],
          regimeBreakdown: {},
          allTrades: [],
          sweepResults: sweepResults
        };
      } else {
        data = await runOneBacktest(baseBody);
      }

      loading.style.display = 'none';
      results.style.display = 'block';

      var diag = document.getElementById('backtest-diagnostic');
      var diagMsg = document.getElementById('backtest-diagnostic-msg');
      diag.style.display = 'none';
      var s = data.summary || {};
      var successResults = (data.results || []).filter(function(r) { return !r.error; });
      if ((s.coinsFailed || 0) > 0 && successResults.length === 0) {
        diag.style.display = 'block';
        var failDetails = (data.failed || []).map(function(f) { return f.coinId + ': ' + f.error; }).join(', ');
        diagMsg.textContent = 'Could not fetch candles for any coin (' + (s.coinsFailed || 0) + ' failed). Errors: ' + (failDetails || 'unknown') + '. Try a single coin and shorter date range.';
      } else if ((s.coinsFailed || 0) > 0) {
        diag.style.display = 'block';
        var partialFails = (data.failed || []).map(function(f) { return f.coinId + ': ' + f.error; }).join(', ');
        diagMsg.textContent = 'Some coins failed (' + s.coinsFailed + '): ' + partialFails;
        diagMsg.style.color = '#f59e0b';
      } else if (successResults.length > 0 && s.totalTrades === 0) {
        diag.style.display = 'block';
        diagMsg.textContent = 'No trades met the criteria across ' + (s.coinsProcessed || successResults.length) + ' coins (' + (s.totalBars || 0) + ' bars). Try lowering Min Score to 48 or a different date range.';
      }

      if (data.walkForward) {
        diag.style.display = 'block';
        diag.style.background = 'rgba(59,130,246,0.1)';
        diag.style.borderColor = 'rgba(59,130,246,0.3)';
        diagMsg.style.color = '#93c5fd';
        diagMsg.textContent = 'Walk-forward: Train ' + (data.walkForward.train?.totalTrades || 0) + ' trades, ' + (data.walkForward.train?.winRate || 0).toFixed(1) + '% WR | Test ' + (data.walkForward.test?.totalTrades || 0) + ' trades, ' + (data.walkForward.test?.winRate || 0).toFixed(1) + '% WR';
      }
      if (data.sweepResults && data.sweepResults.length > 0) {
        var oldSweep = document.getElementById('bt-sweep-results');
        if (oldSweep) oldSweep.remove();
        var sweepDiv = document.createElement('div');
        sweepDiv.id = 'bt-sweep-results';
        sweepDiv.className = 'section';
        sweepDiv.style.marginBottom = '24px';
        sweepDiv.innerHTML = '<h3 style="color:#e5e7eb;margin-bottom:12px;">Parameter Sweep Results</h3><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;">' +
          data.sweepResults.map(function(r) {
            var pnl = r.summary?.totalPnl || 0;
            return '<div style="padding:10px;background:rgba(15,23,42,0.6);border:1px solid #334155;border-radius:8px;"><div style="font-size:11px;color:#6b7280;">Min ' + r.minScore + '</div><div style="font-size:14px;font-weight:700;color:' + (pnl >= 0 ? '#10b981' : '#ef4444') + '">' + (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(0) + '</div><div style="font-size:11px;color:#9ca3af;">' + (r.summary?.totalTrades || 0) + ' trades</div></div>';
          }).join('') + '</div>';
        var firstSection = document.querySelector('#backtest-results .section');
        document.getElementById('backtest-results').insertBefore(sweepDiv, firstSection);
      }

      document.getElementById('bt-trades').textContent = s.totalTrades || 0;
      document.getElementById('bt-winrate').textContent = (s.winRate || 0).toFixed(1) + '%';
      var configEl = document.getElementById('bt-config-used');
      if (configEl) {
        var ib = s.initialBalance ?? 10000;
        var rp = s.riskPerTrade ?? 2;
        var rm = s.riskMode || 'percent';
        var rd = s.riskDollarsPerTrade ?? 200;
        configEl.textContent = 'Config: $' + ib.toLocaleString() + ' initial' + (rm === 'dollar' ? ', $' + rd + '/trade' : ', ' + rp + '% risk');
      }
      var pnl = s.totalPnl || 0;
      var pnlEl = document.getElementById('bt-pnl');
      pnlEl.textContent = (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(2);
      pnlEl.className = 'perf-value ' + (pnl >= 0 ? 'up' : 'down');
      var ret = s.returnPct || 0;
      var retEl = document.getElementById('bt-return');
      retEl.textContent = (ret >= 0 ? '+' : '') + ret.toFixed(2) + '%';
      retEl.className = 'perf-value ' + (ret >= 0 ? 'up' : 'down');
      document.getElementById('bt-pf').textContent = (s.profitFactor || 0).toFixed(2);
      var maxDd = 0;
      successResults.forEach(function(r) { if (r.maxDrawdownPct > maxDd) maxDd = r.maxDrawdownPct; });
      document.getElementById('bt-dd').textContent = maxDd.toFixed(1) + '%';

      // Action badges & exit reasons (aggregate across all coins)
      var totalActions = {};
      var totalExitReasons = {};
      successResults.forEach(function(r) {
        if (r.actionCounts) {
          Object.keys(r.actionCounts).forEach(function(k) { totalActions[k] = (totalActions[k] || 0) + r.actionCounts[k]; });
        }
        if (r.exitReasons) {
          Object.keys(r.exitReasons).forEach(function(k) { totalExitReasons[k] = (totalExitReasons[k] || 0) + r.exitReasons[k]; });
        }
      });
      var badgesEl = document.getElementById('bt-action-badges');
      var exitsEl = document.getElementById('bt-exit-reasons');
      var actionsSection = document.getElementById('bt-actions-section');
      var hasActions = Object.values(totalActions).some(function(v) { return v > 0; });
      var hasExits = Object.keys(totalExitReasons).length > 0;
      actionsSection.style.display = (hasActions || hasExits) ? 'block' : 'none';
      badgesEl.innerHTML = Object.keys(totalActions).filter(function(k) { return totalActions[k] > 0; })
        .map(function(k) { return renderBadge(k, totalActions[k], ACTION_BADGE_MAP); }).join('') || '<span style="color:#374151;font-size:12px;">None</span>';
      exitsEl.innerHTML = Object.keys(totalExitReasons)
        .map(function(k) { return renderBadge(k, totalExitReasons[k], EXIT_REASON_MAP); }).join('') || '<span style="color:#374151;font-size:12px;">None</span>';

      // Equity curve
      var equityCurve = data.equityCurve || [];
      var equityBars = document.getElementById('bt-equity-bars');
      var equityLegend = document.getElementById('bt-equity-legend');
      try {
      equityBars.innerHTML = '';
      if (equityCurve.length > 1) {
        var maxEq = Math.max.apply(null, equityCurve.map(function(p) { return p.equity || 0; }));
        var minEq = Math.min.apply(null, equityCurve.map(function(p) { return p.equity || 0; }));
        var range = maxEq - minEq || 1;
        equityCurve.forEach(function(p, i) {
          var h = maxEq > 0 ? ((p.equity - minEq) / range) * 100 : 0;
          var color = (p.pnl || 0) >= 0 ? '#10b981' : '#ef4444';
          if (i === 0) color = '#6b7280';
          var bar = document.createElement('div');
          bar.style.cssText = 'min-width:4px;flex:1;background:' + color + ';height:' + Math.max(2, h) + '%;border-radius:2px 2px 0 0;cursor:pointer;transition:opacity 0.1s;';
          var dateStr = p.date ? new Date(p.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '';
          var tradeLabel = i === 0 ? 'Start' : 'Trade ' + (p.trade || i);
          bar.title = tradeLabel + (dateStr ? ' · ' + dateStr : '') + '\nEquity: $' + (p.equity || 0).toFixed(0) + (p.pnl != null ? '\nPnL: ' + (p.pnl >= 0 ? '+' : '') + '$' + p.pnl.toFixed(2) : '');
          bar.addEventListener('mouseover', function() { this.style.opacity = '0.75'; });
          bar.addEventListener('mouseout', function() { this.style.opacity = '1'; });
          equityBars.appendChild(bar);
        });
        var first = equityCurve[0];
        var last = equityCurve[equityCurve.length - 1];
        var dateRange = (first.date && last.date)
          ? new Date(first.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) + ' → ' + new Date(last.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })
          : '';
        equityLegend.textContent = 'Start: $' + (first.equity || 0).toLocaleString() + ' → End: $' + (last.equity || 0).toLocaleString() + ' · ' + (equityCurve.length - 1) + ' trades' + (dateRange ? ' · ' + dateRange : '');
      } else {
        equityLegend.textContent = 'No equity data (no trades closed)';
      }
      } catch (chartErr) {
        console.warn('Backtest equity chart error:', chartErr);
        if (equityBars) equityBars.innerHTML = '<p style="color:#9ca3af;padding:16px;text-align:center;">Chart could not be loaded.</p>';
        if (equityLegend) equityLegend.textContent = 'Chart error';
      }

      // Robustness evaluation (from first successful coin)
      var firstWithEval = successResults.find(function(r) { return r.evaluation; });
      var robSection = document.getElementById('bt-robustness-section');
      if (robSection) robSection.remove();
      if (firstWithEval && firstWithEval.evaluation) {
        var ev = firstWithEval.evaluation;
        var robDiv = document.createElement('div');
        robDiv.id = 'bt-robustness-section';
        robDiv.className = 'section';
        robDiv.style.marginBottom = '24px';
        robDiv.style.background = 'rgba(15,23,42,0.6)';
        robDiv.style.border = '1px solid #334155';
        robDiv.style.borderRadius = '8px';
        robDiv.style.padding = '16px';
        var verdictColor = ev.verdict === 'deploy' ? '#10b981' : ev.verdict === 'refine' ? '#eab308' : '#ef4444';
        var flagsHtml = (ev.redFlags || []).length > 0 ? '<div style="font-size:12px;color:#fca5a5;margin-top:8px;">' + (ev.redFlags || []).map(function(f) { return '• ' + f.msg; }).join('<br>') + '</div>' : '';
        var yearHtml = '';
        if (ev.byYear && Object.keys(ev.byYear).filter(function(k) { return k !== 'unknown'; }).length > 0) {
          var years = Object.keys(ev.byYear).filter(function(k) { return k !== 'unknown'; }).sort();
          yearHtml = '<div style="font-size:11px;color:#9ca3af;margin-top:8px;">Year-by-year: ' + years.map(function(y) {
            var d = ev.byYear[y];
            return '<span style="margin-right:8px;padding:2px 6px;border-radius:4px;background:rgba(30,41,59,0.8);color:' + ((d.pnl || 0) >= 0 ? '#10b981' : '#ef4444') + '">' + y + ': $' + (d.pnl || 0).toFixed(0) + ' (' + d.trades + ')</span>';
          }).join('') + '</div>';
        }
        robDiv.innerHTML = '<h3 style="color:#e5e7eb;margin-bottom:12px;">Robustness Check (' + (firstWithEval.symbol || firstWithEval.coinId) + ')</h3>' +
          '<div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;">' +
          '<span style="padding:4px 10px;border-radius:6px;font-weight:600;font-size:12px;background:' + verdictColor + '22;color:' + verdictColor + '">' + (ev.verdict || 'deploy').toUpperCase() + '</span>' +
          (ev.sampleSizeOk ? '<span style="font-size:11px;color:#10b981">✓ Sample size OK</span>' : '<span style="font-size:11px;color:#eab308">⚠ Low sample</span>') +
          (ev.regimeRobust ? '<span style="font-size:11px;color:#10b981">✓ Regime robust</span>' : '<span style="font-size:11px;color:#eab308">⚠ Regime dependent</span>') +
          '</div>' + flagsHtml + yearHtml;
        var firstSection = document.querySelector('#backtest-results .section');
        document.getElementById('backtest-results').insertBefore(robDiv, firstSection);
      }

      // Regime breakdown
      var regimeBreakdown = data.regimeBreakdown || {};
      var regimeGrid = document.getElementById('bt-regime-grid');
      regimeGrid.innerHTML = '';
      Object.keys(regimeBreakdown).forEach(function(r) {
        var rd = regimeBreakdown[r];
        var wr = rd.trades > 0 ? ((rd.wins / rd.trades) * 100).toFixed(0) : '-';
        var pnl = rd.pnl || 0;
        var card = document.createElement('div');
        card.style.cssText = 'padding:10px 12px;background:rgba(15,23,42,0.6);border:1px solid #334155;border-radius:8px;';
        card.innerHTML = '<div style="font-size:11px;color:#6b7280;text-transform:uppercase;margin-bottom:4px;">' + r + '</div>' +
          '<div style="font-size:16px;font-weight:700;color:#e5e7eb;">' + rd.trades + ' trades</div>' +
          '<div style="font-size:12px;color:' + (wr >= 50 ? '#10b981' : '#ef4444') + '">' + wr + '% WR</div>' +
          '<div style="font-size:12px;color:' + (pnl >= 0 ? '#10b981' : '#ef4444') + '">' + (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(2) + '</div>';
        regimeGrid.appendChild(card);
      });
      if (Object.keys(regimeBreakdown).length === 0) {
        regimeGrid.innerHTML = '<span style="color:#6b7280;font-size:13px;">No regime data (trades have no regime tag)</span>';
      }

      // Data coverage banner
      var oldCovBanner = document.getElementById('bt-coverage-banner');
      if (oldCovBanner) oldCovBanner.remove();
      if (successResults.length > 0) {
        var covBanner = document.createElement('div');
        covBanner.id = 'bt-coverage-banner';
        covBanner.style.cssText = 'padding:10px 14px;margin-bottom:16px;background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:8px;display:flex;flex-wrap:wrap;gap:10px;align-items:center;';
        var covHtml = '<span style="font-size:12px;font-weight:600;color:#93c5fd;">Data Coverage</span>';
        successResults.forEach(function(r) {
          var from = r.firstBarTime ? new Date(r.firstBarTime).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '?';
          var to   = r.lastBarTime  ? new Date(r.lastBarTime).toLocaleDateString('en-GB',  { day:'2-digit', month:'short', year:'numeric' }) : '?';
          var days = (r.firstBarTime && r.lastBarTime) ? Math.round((r.lastBarTime - r.firstBarTime) / 86400000) : 0;
          covHtml += '<span style="font-size:12px;color:#e5e7eb;padding:3px 8px;background:rgba(15,23,42,0.6);border-radius:5px;">' +
            '<strong style="color:#6b7280;">' + (r.symbol || r.coinId) + '</strong> ' +
            from + ' → ' + to + ' <span style="color:#6b7280;">(' + (r.bars || 0) + ' 1h bars · ' + days + ' days)</span></span>';
        });
        covBanner.innerHTML = covHtml;
        var coinsSection = document.querySelector('#backtest-results .section:last-of-type');
        var summarySection = document.getElementById('backtest-results').querySelector('.section');
        if (summarySection) summarySection.insertAdjacentElement('afterend', covBanner);
      }

      // Per-coin table (only successful runs)
      var tbody = document.getElementById('bt-coins-body');
      tbody.innerHTML = '';
      successResults.forEach(function(r) {
        var tr = document.createElement('tr');
        var wr = r.winRate || 0;
        var pnl = r.totalPnl || 0;
        var ret = r.returnPct || 0;
        var from = r.firstBarTime ? new Date(r.firstBarTime).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'2-digit' }) : '-';
        var to   = r.lastBarTime  ? new Date(r.lastBarTime).toLocaleDateString('en-GB',  { day:'2-digit', month:'short', year:'2-digit' }) : '-';
        tr.innerHTML = '<td data-label="Coin"><strong>' + (r.symbol || r.coinId) + '</strong><br><span style="font-size:10px;color:#6b7280;">' + from + ' – ' + to + ' · ' + (r.bars || 0) + ' bars</span></td>' +
          '<td data-label="Trades">' + (r.totalTrades || 0) + '</td>' +
          '<td data-label="Wins" class="up">' + (r.wins || 0) + '</td>' +
          '<td data-label="Losses" class="down">' + (r.losses || 0) + '</td>' +
          '<td data-label="Win Rate" style="color:' + (wr >= 50 ? '#10b981' : '#ef4444') + '">' + wr.toFixed(1) + '%</td>' +
          '<td data-label="PnL" class="' + (pnl >= 0 ? 'up' : 'down') + '">' + (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(2) + '</td>' +
          '<td data-label="Return %" class="' + (ret >= 0 ? 'up' : 'down') + '">' + (ret >= 0 ? '+' : '') + ret.toFixed(2) + '%</td>' +
          '<td data-label="Max DD %" class="down">' + (r.maxDrawdownPct || 0).toFixed(1) + '%</td>';
        tbody.appendChild(tr);
      });

      // Trade list (aggregate from successful results, sorted by exit time)
      var allTrades = [];
      successResults.forEach(function(r) {
        (r.trades || []).forEach(function(t) {
          allTrades.push({ coinId: r.coinId, symbol: r.symbol, direction: t.direction, entry: t.entry, exit: t.exit, exitTime: t.exitTime, entryBar: t.entryBar, reason: t.reason, pnl: t.pnl, actions: t.actions || [] });
        });
      });
      allTrades.sort(function(a, b) { return (a.exitTime || 0) - (b.exitTime || 0); });
      var tradesBody = document.getElementById('bt-trades-body');
      tradesBody.innerHTML = '';
      // Update the trade table header to include Date column
      var tHead = document.querySelector('#bt-trades-table thead tr');
      if (tHead && !tHead.querySelector('.bt-date-col')) {
        var dateTh = document.createElement('th');
        dateTh.className = 'bt-date-col';
        dateTh.textContent = 'Date';
        tHead.insertBefore(dateTh, tHead.firstChild);
      }
      allTrades.slice(0, 200).forEach(function(t) {
        var tr = document.createElement('tr');
        var dateStr = t.exitTime ? new Date(t.exitTime).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'2-digit' }) : '-';
        tr.innerHTML = '<td data-label="Date" style="font-size:11px;color:#9ca3af;">' + dateStr + '</td>' +
          '<td data-label="Coin">' + (t.symbol || t.coinId) + '</td>' +
          '<td data-label="Dir"><span class="badge-' + (t.direction === 'LONG' ? 'BUY' : 'SELL') + '" style="padding:2px 6px;border-radius:4px;font-size:11px;">' + t.direction + '</span></td>' +
          '<td data-label="Entry">$' + Number(t.entry || 0).toFixed(4) + '</td>' +
          '<td data-label="Exit">$' + Number(t.exit || 0).toFixed(4) + '</td>' +
          '<td data-label="Reason">' + (t.reason || '-') + '</td>' +
          '<td data-label="Actions">' + renderActionBadgesForTrade(t.actions) + '</td>' +
          '<td data-label="PnL" class="' + ((t.pnl || 0) >= 0 ? 'up' : 'down') + '">' + ((t.pnl || 0) >= 0 ? '+' : '') + '$' + (t.pnl || 0).toFixed(2) + '</td>';
        tradesBody.appendChild(tr);
      });
      if (allTrades.length > 200) {
        var more = document.createElement('tr');
        more.innerHTML = '<td colspan="8" style="color:#6b7280;font-size:12px;">Showing first 200 of ' + allTrades.length + ' trades</td>';
        tradesBody.appendChild(more);
      }
    } catch (err) {
      loading.style.display = 'none';
      var msg = err.message || 'Backtest failed';
      // Fallback friendly message for raw network/parse errors
      if (msg === 'Failed to fetch' || err.name === 'AbortError') {
        msg = 'Request timed out or network error. Try fewer coins or a shorter date range.';
      }
      // Show in a styled banner instead of a plain alert
      var errBanner = document.getElementById('bt-error-banner');
      if (errBanner) {
        errBanner.textContent = msg;
        errBanner.style.display = 'block';
        errBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        alert(msg);
      }
    }
    runBtn.disabled = false;
  });
})();
</script>
<style>
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
.perf-card { background: rgba(15,23,42,0.6); border: 1px solid #1e2a3a; border-radius: 8px; padding: 12px 16px; }
.perf-label { font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
.perf-value { font-size: 18px; font-weight: 700; color: #e5e7eb; margin-top: 4px; }
/* Feature toggle styles */
.ft-toggle {
  display: flex; align-items: center; gap: 8px; padding: 6px 10px;
  background: rgba(15,23,42,0.5); border: 1px solid #1e2a3a; border-radius: 6px;
  color: #e5e7eb; font-size: 12px; cursor: pointer; transition: border-color 0.2s;
}
.ft-toggle:hover { border-color: #334155; }
.ft-toggle input[type=checkbox] { accent-color: #3b82f6; width: 14px; height: 14px; cursor: pointer; }
.ft-badge { padding: 1px 5px; border-radius: 3px; font-size: 9px; font-weight: 700; letter-spacing: 0.5px; }
.ft-signal { background: #3b82f622; color: #3b82f6; }
.ft-pos { background: #10b98122; color: #10b981; }
.ft-risk { background: #f59e0b22; color: #f59e0b; }
.ft-cost { background: #8b5cf622; color: #8b5cf6; }
.ft-fix { background: #ef444422; color: #ef4444; }
</style>

</div><!-- .backtest-page -->

<%- include('partials/footer') %>
