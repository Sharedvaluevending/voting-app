    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .trench-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .trench-stat {
    padding: 24px;
    border: 1px solid rgba(255, 51, 85, 0.2);
    border-radius: 12px;
    background: rgba(255, 51, 85, 0.03);
    text-align: center;
