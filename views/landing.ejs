<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AlphaConfluence — AI-Powered Crypto Trading Platform</title>
<meta name="description" content="Professional crypto trading signals with multi-strategy scoring, 40 coins, 7 strategies, 16 SMC setups, AI agent, and paper trading.">
<meta name="theme-color" content="#020810">
<link rel="icon" type="image/png" href="/images/logo-icon.png">
<link rel="apple-touch-icon" href="/images/logo-icon.png">
<link rel="manifest" href="/manifest.json">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cyan: #00d4ff;
    --blue: #0066ff;
    --dark-blue: #003399;
    --bg: #020810;
    --bg2: #040f1e;
    --bg3: #061428;
    --text: #e8f4ff;
    --muted: #5a7a9a;
    --green: #00ff88;
    --red: #ff3355;
    --gold: #ffd700;
    --border: rgba(0, 212, 255, 0.15);
    --glow: rgba(0, 212, 255, 0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* GRID BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    padding: 20px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(2, 8, 16, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo-icon {
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: white;
    box-shadow: 0 0 20px var(--glow);
  }

  .nav-logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cyan); }

  .nav-cta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn-ghost {
    padding: 10px 24px;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
    background: transparent;
    cursor: pointer;
  }

  .btn-ghost:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .btn-primary {
    padding: 10px 24px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    border: none;
    border-radius: 8px;
    color: #000;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.5);
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(0, 102, 255, 0.15) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-glow2 {
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.1) 0%, transparent 70%);
    top: 30%;
    right: 15%;
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border: 1px solid rgba(0, 255, 136, 0.3);
    border-radius: 100px;
    background: rgba(0, 255, 136, 0.05);
    font-size: 13px;
    font-weight: 600;
    color: var(--green);
    margin-bottom: 32px;
    letter-spacing: 1px;
  }

  .hero-badge::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(64px, 10vw, 140px);
    line-height: 0.9;
    letter-spacing: 3px;
    margin-bottom: 8px;
  }

  .hero-title span {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--blue) 50%, #8844ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
  }

  .hero-subtitle-large {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(24px, 4vw, 48px);
    letter-spacing: 8px;
    color: var(--muted);
    margin-bottom: 32px;
  }

  .hero-desc {
    font-size: 18px;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto 48px;
    line-height: 1.7;
    font-weight: 400;
  }

  .hero-desc strong {
    color: var(--cyan);
    font-weight: 600;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 64px;
  }

  .btn-hero {
    padding: 18px 48px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    border: none;
    border-radius: 12px;
    color: #000;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 0 40px rgba(0, 212, 255, 0.4);
    letter-spacing: 0.5px;
  }

  .btn-hero:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 60px rgba(0, 212, 255, 0.6);
  }

  .btn-hero-ghost {
    padding: 18px 48px;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s;
    background: rgba(255,255,255,0.03);
  }

  .btn-hero-ghost:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    background: rgba(0, 212, 255, 0.05);
  }

  /* STATS BAR */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(4, 15, 30, 0.8);
    backdrop-filter: blur(10px);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* LIVE TICKER */
  .ticker-section {
    padding: 40px 0;
    overflow: hidden;
    position: relative;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(4, 15, 30, 0.5);
  }

  .ticker-track {
    display: flex;
    gap: 48px;
    animation: ticker 30s linear infinite;
    white-space: nowrap;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
  }

  .ticker-coin { color: var(--text); font-weight: 700; }
  .ticker-price { color: var(--muted); }
  .ticker-up { color: var(--green); }
  .ticker-down { color: var(--red); }
  .ticker-signal {
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
  }
  .signal-buy { background: rgba(0, 255, 136, 0.15); color: var(--green); }
  .signal-sell { background: rgba(255, 51, 85, 0.15); color: var(--red); }
  .signal-hold { background: rgba(255, 215, 0, 0.15); color: var(--gold); }

  /* SECTIONS */
  section {
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .section-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 16px;
    padding: 6px 16px;
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 4px;
    background: rgba(0, 212, 255, 0.05);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: 16px;
  }

  .section-title span {
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-desc {
    font-size: 16px;
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* FEATURES GRID */
  .features-section {
    padding: 120px 60px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .feature-card {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(4, 15, 30, 0.6);
    backdrop-filter: blur(10px);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .feature-card:hover {
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .feature-card:hover::before { opacity: 1; }

  .feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 20px;
  }

  .icon-cyan { background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.2); }
  .icon-blue { background: rgba(0, 102, 255, 0.1); border: 1px solid rgba(0, 102, 255, 0.2); }
  .icon-green { background: rgba(0, 255, 136, 0.1); border: 1px solid rgba(0, 255, 136, 0.2); }
  .icon-gold { background: rgba(255, 215, 0, 0.1); border: 1px solid rgba(255, 215, 0, 0.2); }
  .icon-purple { background: rgba(136, 68, 255, 0.1); border: 1px solid rgba(136, 68, 255, 0.2); }
  .icon-red { background: rgba(255, 51, 85, 0.1); border: 1px solid rgba(255, 51, 85, 0.2); }

  .feature-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }

  .feature-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .feature-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 4px;
    background: rgba(0, 212, 255, 0.08);
    color: var(--cyan);
    border: 1px solid rgba(0, 212, 255, 0.15);
  }

  /* BIG FEATURE SHOWCASE */
  .showcase-section {
    padding: 120px 60px;
    background: linear-gradient(180deg, transparent, rgba(4, 15, 30, 0.8), transparent);
  }

  .showcase-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .showcase-grid.reverse { direction: rtl; }
  .showcase-grid.reverse > * { direction: ltr; }

  .showcase-content h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    letter-spacing: 2px;
    margin-bottom: 16px;
    line-height: 1;
  }

  .showcase-content h3 span {
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .showcase-content p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .showcase-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .showcase-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--text);
  }

  .showcase-list li::before {
    content: '→';
    color: var(--cyan);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* MOCK DASHBOARD */
  .mock-dashboard {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg2);
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 0 60px rgba(0, 102, 255, 0.1);
  }

  .mock-header {
    padding: 16px 20px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mock-dots {
    display: flex;
    gap: 6px;
  }

  .mock-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .mock-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  .mock-body { padding: 20px; }

  /* SIGNAL CARD MOCK */
  .mock-signal-card {
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: 12px;
    padding: 20px;
    background: rgba(0, 255, 136, 0.03);
    margin-bottom: 12px;
  }

  .mock-signal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .mock-coin {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
  }

  .mock-badge {
    padding: 6px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
  }

  .badge-buy { background: rgba(0, 255, 136, 0.2); color: var(--green); }
  .badge-sell { background: rgba(255, 51, 85, 0.2); color: var(--red); }
  .badge-hold { background: rgba(255, 215, 0, 0.2); color: var(--gold); }

  .mock-score-bar {
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
    height: 6px;
    margin-bottom: 8px;
    overflow: hidden;
  }

  .mock-score-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--blue));
    border-radius: 4px;
  }

  .mock-score-labels {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 16px;
  }

  .mock-levels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .mock-level {
    text-align: center;
    padding: 8px;
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .mock-level-label {
    font-size: 10px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 4px;
  }

  .mock-level-value {
    font-size: 13px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
  }

  .entry-val { color: var(--cyan); }
  .sl-val { color: var(--red); }
  .tp-val { color: var(--green); }
  .rr-val { color: var(--gold); }

  /* AI AGENT MOCK */
  .mock-ai-response {
    border: 1px solid rgba(136, 68, 255, 0.2);
    border-radius: 12px;
    padding: 16px;
    background: rgba(136, 68, 255, 0.03);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    font-family: 'JetBrains Mono', monospace;
  }

  .mock-ai-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    color: #8844ff;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
  }

  /* SCORE BREAKDOWN MOCK */
  .score-breakdown {
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(4, 15, 30, 0.8);
  }

  .score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .score-row:last-child { border-bottom: none; }

  .score-label {
    font-size: 13px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .score-bar-wrap {
    flex: 1;
    margin: 0 16px;
    height: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
  }

  .score-bar-fill {
    height: 100%;
    border-radius: 2px;
  }

  .score-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    width: 40px;
    text-align: right;
  }

  /* STRATEGY TABLE */
  .strategy-section {
    padding: 120px 60px;
  }

  .strategy-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .strategy-card {
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(4, 15, 30, 0.7);
    transition: all 0.3s;
  }

  .strategy-card:hover {
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-3px);
  }

  .strategy-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }

  .strategy-regime {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 12px;
  }

  .regime-trending { background: rgba(0, 212, 255, 0.1); color: var(--cyan); }
  .regime-ranging { background: rgba(255, 215, 0, 0.1); color: var(--gold); }
  .regime-compression { background: rgba(136, 68, 255, 0.1); color: #8844ff; }
  .regime-volatile { background: rgba(255, 51, 85, 0.1); color: var(--red); }
  .regime-all { background: rgba(0, 255, 136, 0.1); color: var(--green); }

  .strategy-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* SMC SETUPS */
  .setups-section {
    padding: 120px 60px;
    background: linear-gradient(180deg, transparent, rgba(0, 20, 60, 0.3), transparent);
  }

  .setups-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }

  .setup-card {
    padding: 20px 24px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(4, 15, 30, 0.6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s;
  }

  .setup-card:hover {
