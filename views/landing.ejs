  .trench-stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: #ff6633;
    letter-spacing: 2px;
  }

  .trench-stat-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

