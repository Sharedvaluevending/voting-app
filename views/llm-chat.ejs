<%- include('partials/header') %>

<div class="section-header">
  <h2 style="color:#fff;font-size:22px;">LLM Chat</h2>
  <p style="color:#9ca3af;font-size:13px;margin-top:6px;">Ask about markets, trades, strategies, and your platform. The LLM has full access to your data.</p>
</div>

<div style="margin-bottom:12px;padding:12px 16px;background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.3);border-radius:8px;font-size:12px;color:#c4b5fd;">
  Requires Ollama running with your model (e.g. qwen3-coder:480b-cloud). Configure URL and model in <a href="/performance" style="color:#a78bfa;">Performance</a>.
</div>

<div class="section" style="display:flex;flex-direction:column;height:calc(100vh - 220px);min-height:400px;background:rgba(15,23,42,0.6);border:1px solid #1e2a3a;border-radius:12px;backdrop-filter:blur(8px);overflow:hidden;">
  <div id="chat-messages" style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;">
    <div id="chat-welcome" style="padding:16px;background:rgba(30,41,59,0.5);border:1px solid #334155;border-radius:8px;color:#9ca3af;font-size:13px;">
      <strong style="color:#a78bfa;">Examples:</strong><br>
      • "What's the market doing right now?"<br>
      • "Summarize my open trades and P&L"<br>
      • "Move my SOL stop to breakeven" <em style="color:#8b5cf6;">(check Execute actions)</em><br>
      • "Close my BTC trade" <em style="color:#8b5cf6;">(check Execute actions)</em><br>
      • "What are my current risk settings?"
    </div>
  </div>
  <div style="padding:12px 16px;border-top:1px solid #1e2a3a;background:rgba(15,23,42,0.4);">
    <form id="chat-form" style="display:flex;flex-direction:column;gap:8px;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="display:flex;gap:8px;align-items:flex-end;">
        <textarea id="chat-input" name="message" rows="2" placeholder="Ask about markets, trades, strategies... Or: 'Move my SOL stop to breakeven', 'Close my BTC trade'" style="flex:1;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#fff;font-size:14px;resize:none;min-height:44px;max-height:120px;" required></textarea>
        <button type="button" id="chat-mic" title="Hold to talk" style="padding:10px;height:44px;width:44px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#9ca3af;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;">
          <svg id="mic-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 1 3 3v8a3 3 0 0 1-6 0V4a3 3 0 0 1 3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </button>
        <button type="submit" id="chat-send" class="btn btn-primary" style="padding:10px 20px;height:44px;">Send</button>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:12px 20px;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:12px;color:#9ca3af;">
          <input type="checkbox" id="execute-actions" name="executeActions" style="accent-color:#8b5cf6;">
          Execute actions (run agent to close trades, move stops, change settings, etc.)
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:12px;color:#9ca3af;">
          <input type="checkbox" id="speak-response" checked style="accent-color:#8b5cf6;">
          Speak response
        </label>
      </div>
    </form>
    <div id="chat-status" style="font-size:11px;color:#6b7280;margin-top:6px;"></div>
  </div>
</div>

<style>
#chat-messages .msg-user { align-self:flex-end; max-width:85%; padding:10px 14px; background:rgba(59,130,246,0.2); border:1px solid rgba(59,130,246,0.3); border-radius:10px; color:#e5e7eb; font-size:14px; }
#chat-messages .msg-assistant { align-self:flex-start; max-width:90%; padding:12px 16px; background:rgba(30,41,59,0.6); border:1px solid #334155; border-radius:10px; color:#e5e7eb; font-size:14px; line-height:1.5; white-space:pre-wrap; }
#chat-messages .msg-error { align-self:flex-start; padding:10px 14px; background:rgba(239,68,68,0.15); border:1px solid rgba(239,68,68,0.3); border-radius:8px; color:#fca5a5; font-size:13px; }
#chat-messages .msg-agent { align-self:flex-start; max-width:90%; padding:12px 16px; background:rgba(139,92,246,0.15); border:1px solid rgba(139,92,246,0.4); border-radius:10px; color:#c4b5fd; font-size:13px; }
#chat-mic.recording { background:rgba(239,68,68,0.2); border-color:rgba(239,68,68,0.5); color:#fca5a5; }
#chat-mic:hover { border-color:#64748b; color:#e5e7eb; }
</style>

<script>
(function() {
  var form = document.getElementById('chat-form');
  var input = document.getElementById('chat-input');
  var messagesEl = document.getElementById('chat-messages');
  var welcomeEl = document.getElementById('chat-welcome');
  var statusEl = document.getElementById('chat-status');
  var sendBtn = document.getElementById('chat-send');
  var micBtn = document.getElementById('chat-mic');
  var history = [];

  var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  var recognition = SpeechRecognition ? new SpeechRecognition() : null;
  if (recognition) {
    recognition.continuous = true;
    recognition.interimResults = true;
    recognition.lang = 'en-US';
  }

  function speakText(text) {
    if (!window.speechSynthesis || !text || !document.getElementById('speak-response').checked) return;
    var CHUNK_LIMIT = 14000;
    var chunks = [];
    if (text.length <= CHUNK_LIMIT) {
      chunks = [text];
    } else {
      var remaining = text;
      while (remaining.length > 0) {
        var chunk = remaining.slice(0, CHUNK_LIMIT);
        var lastPeriod = chunk.lastIndexOf('.');
        var lastNewline = chunk.lastIndexOf('\n');
        var splitAt = Math.max(lastPeriod, lastNewline, 0);
        if (splitAt > 0) {
          chunks.push(chunk.slice(0, splitAt + 1));
          remaining = remaining.slice(splitAt + 1);
        } else {
          chunks.push(chunk);
          remaining = remaining.slice(CHUNK_LIMIT);
        }
      }
    }
    speechSynthesis.cancel();
    chunks.forEach(function(chunk, i) {
      var u = new SpeechSynthesisUtterance(chunk);
      u.rate = 0.95;
      speechSynthesis.speak(u);
    });
  }

  function sendMessage(text) {
    text = (text || '').trim();
    if (!text) return;

    welcomeEl.style.display = 'none';
    history.push({ role: 'user', content: text });
    var userDiv = document.createElement('div');
    userDiv.className = 'msg-user';
    userDiv.textContent = text;
    messagesEl.appendChild(userDiv);
    messagesEl.scrollTop = messagesEl.scrollHeight;

    input.value = '';
    sendBtn.disabled = true;
    micBtn.disabled = true;
    statusEl.textContent = 'Thinking...';

    var executeActions = document.getElementById('execute-actions').checked;
    fetch('/api/llm-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value },
      body: JSON.stringify({ messages: history, executeActions: executeActions }),
      credentials: 'same-origin'
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      sendBtn.disabled = false;
      micBtn.disabled = false;
      statusEl.textContent = '';
      if (d.success && d.text) {
        history.push({ role: 'assistant', content: d.text });
        var div = document.createElement('div');
        div.className = 'msg-assistant';
        div.textContent = d.text;
        messagesEl.appendChild(div);
        speakText(d.text);
        if (d.agentResult) {
          var ar = d.agentResult;
          var agentLines = [];
          if (ar.reasoning) agentLines.push(ar.reasoning);
          if (ar.actionsExecuted && ar.actionsExecuted.length) agentLines.push('Executed: ' + ar.actionsExecuted.map(function(a){ return a.message; }).join('; '));
          if (ar.actionsFailed && ar.actionsFailed.length) agentLines.push('Failed: ' + ar.actionsFailed.map(function(a){ return a.message; }).join('; '));
          if (agentLines.length) {
            var agentDiv = document.createElement('div');
            agentDiv.className = 'msg-agent';
            agentDiv.textContent = agentLines.join('\n');
            messagesEl.appendChild(agentDiv);
          }
        }
        if (d.agentError) {
          var errDiv = document.createElement('div');
          errDiv.className = 'msg-error';
          errDiv.textContent = 'Agent error: ' + d.agentError;
          messagesEl.appendChild(errDiv);
        }
      } else {
        history.pop();
        var errDiv = document.createElement('div');
        errDiv.className = 'msg-error';
        errDiv.textContent = d.error || 'Failed to get response';
        messagesEl.appendChild(errDiv);
      }
      messagesEl.scrollTop = messagesEl.scrollHeight;
    })
    .catch(function(err) {
      sendBtn.disabled = false;
      micBtn.disabled = false;
      statusEl.textContent = '';
      history.pop();
      var errDiv = document.createElement('div');
      errDiv.className = 'msg-error';
      errDiv.textContent = err.message || 'Network error';
      messagesEl.appendChild(errDiv);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    });
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    sendMessage(input.value);
  });

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });

  if (recognition) {
    var transcript = '';
    function onResult(e) {
      var r = '';
      for (var i = e.resultIndex; i < e.results.length; i++) {
        if (e.results[i].isFinal) r += e.results[i][0].transcript;
      }
      if (r) transcript += r;
    }
    function onEnd() {
      micBtn.classList.remove('recording');
      micBtn.disabled = false;
      statusEl.textContent = '';
      recognition.onresult = null;
      recognition.onend = null;
      recognition.onerror = null;
      var t = transcript.trim();
      if (t) sendMessage(t);
      transcript = '';
    }
    function onError(e) {
      if (e.error === 'not-allowed') statusEl.textContent = 'Microphone access denied';
      onEnd();
    }
    micBtn.addEventListener('mousedown', function(e) {
      if (e.button !== 0) return;
      transcript = '';
      micBtn.classList.add('recording');
      micBtn.disabled = true;
      statusEl.textContent = 'Listening...';
      recognition.onresult = onResult;
      recognition.onend = onEnd;
      recognition.onerror = onError;
      recognition.start();
    });
    micBtn.addEventListener('mouseup', function() { recognition.stop(); });
    micBtn.addEventListener('mouseleave', function() { if (micBtn.classList.contains('recording')) recognition.stop(); });
    micBtn.addEventListener('touchstart', function(e) {
      e.preventDefault();
      transcript = '';
      micBtn.classList.add('recording');
      micBtn.disabled = true;
      statusEl.textContent = 'Listening...';
      recognition.onresult = onResult;
      recognition.onend = onEnd;
      recognition.onerror = onError;
      recognition.start();
    }, { passive: false });
    micBtn.addEventListener('touchend', function(e) {
      e.preventDefault();
      recognition.stop();
    }, { passive: false });
  } else {
    micBtn.style.display = 'none';
  }
})();
</script>

<%- include('partials/footer') %>
