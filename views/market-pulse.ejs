<%- include('partials/header') %>

<div class="section-header">
  <h2 style="color:#fff;font-size:22px;">Market Pulse</h2>
  <p style="color:#9ca3af;font-size:13px;margin-top:6px;">Fear & Greed Index, BTC dominance, and market overview. Market-news-analyst skill inspired — use for context before trading.</p>
</div>

<div class="themes-info-box market-context">
  <h3 style="color:#3b82f6;font-size:13px;margin:0 0 8px 0;">Market Context</h3>
  <p style="color:#9ca3af;font-size:12px;margin:0;">Extreme Fear often precedes bounces; Extreme Greed can signal tops. Combine with signals for better timing.</p>
</div>

<% if (pulse) { %>
<div class="pulse-grid">
  <div class="pulse-card">
    <div class="pulse-card-label">Fear & Greed</div>
    <% if (pulse.fearGreed && pulse.fearGreed.value != null) {
      var v = pulse.fearGreed.value;
      var fgColor = v <= 25 ? '#ef4444' : v <= 45 ? '#eab308' : v <= 55 ? '#9ca3af' : v <= 75 ? '#10b981' : '#3b82f6';
    %>
    <div class="pulse-card-value" style="color:<%= fgColor %>;"><%= v %></div>
    <div class="pulse-card-sub"><%= pulse.fearGreed.classification %></div>
    <% } else { %>
    <div class="pulse-card-value" style="color:#6b7280;font-size:16px;">—</div>
    <% } %>
  </div>
  <div class="pulse-card">
    <div class="pulse-card-label">BTC Dominance</div>
    <% if (pulse.global && pulse.global.btcDominance != null) { %>
    <div class="pulse-card-value" style="color:#f59e0b;"><%= pulse.global.btcDominance.toFixed(1) %>%</div>
    <div class="pulse-card-sub">of total market cap</div>
    <% } else { %>
    <div class="pulse-card-value" style="color:#6b7280;font-size:16px;">—</div>
    <% } %>
  </div>
  <div class="pulse-card">
    <div class="pulse-card-label">ETH Dominance</div>
    <% if (pulse.global && pulse.global.ethDominance != null) { %>
    <div class="pulse-card-value" style="color:#6366f1;"><%= pulse.global.ethDominance.toFixed(1) %>%</div>
    <% } else { %>
    <div class="pulse-card-value" style="color:#6b7280;font-size:16px;">—</div>
    <% } %>
  </div>
  <div class="pulse-card">
    <div class="pulse-card-label">Market Cap 24h</div>
    <% if (pulse.global && pulse.global.marketCapChange24h != null) {
      var ch = pulse.global.marketCapChange24h;
    %>
    <div class="pulse-card-value" style="color:<%= ch >= 0 ? '#10b981' : '#ef4444' %>;"><%= ch >= 0 ? '+' : '' %><%= ch.toFixed(2) %>%</div>
    <% } else { %>
    <div class="pulse-card-value" style="color:#6b7280;font-size:16px;">—</div>
    <% } %>
  </div>
  <div class="pulse-card">
    <div class="pulse-card-label">Volume 24h</div>
    <% if (pulse.global && pulse.global.volumeChange24h != null) {
      var vch = pulse.global.volumeChange24h;
    %>
    <div class="pulse-card-value" style="color:<%= vch >= 0 ? '#10b981' : '#ef4444' %>;"><%= vch >= 0 ? '+' : '' %><%= vch.toFixed(1) %>%</div>
    <% } else { %>
    <div class="pulse-card-value" style="color:#6b7280;font-size:16px;">—</div>
    <% } %>
  </div>
</div>
<% } else { %>
<div class="section" style="padding:24px;background:rgba(15,23,42,0.6);border:1px solid #1e2a3a;border-radius:8px;">
  <p style="color:#6b7280;font-size:13px;">Loading market pulse... Refresh in a moment.</p>
</div>
<% } %>
<%- include('partials/footer') %>
