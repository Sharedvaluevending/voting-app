<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %>AlphaConfluence</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0a0e17">
  <meta name="color-scheme" content="dark">
  <link rel="icon" type="image/png" href="/images/logo-icon.png">
  <link rel="apple-touch-icon" href="/images/logo-icon.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="logo"><img src="/images/logo-icon.png" alt="AlphaConfluence" class="logo-icon"><span>Alpha</span>Confluence</a>
      <button type="button" class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">Menu</button>
      <div class="nav-links" id="nav-links">
        <a href="/" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>

        <div class="nav-dropdown <%= ['trades','history','setups','journal','performance','exchange'].indexOf(typeof activePage !== 'undefined' ? activePage : '') >= 0 ? 'active' : '' %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">Trading ▾</button>
          <div class="nav-dropdown-menu">
            <% if (typeof user !== 'undefined' && user) { %>
            <a href="/trades" class="<%= typeof activePage !== 'undefined' && activePage === 'trades' ? 'active' : '' %>">Trades</a>
            <a href="/history" class="<%= typeof activePage !== 'undefined' && activePage === 'history' ? 'active' : '' %>">History</a>
            <% } %>
            <a href="/setups" class="<%= typeof activePage !== 'undefined' && activePage === 'setups' ? 'active' : '' %>" id="nav-setups-link">Setups<span id="setup-notif-badge" style="display:none;margin-left:4px;padding:1px 5px;background:#10b981;color:#0f172a;border-radius:10px;font-size:10px;font-weight:700;"></span></a>
            <% if (typeof user !== 'undefined' && user) { %>
            <a href="/journal" class="<%= typeof activePage !== 'undefined' && activePage === 'journal' ? 'active' : '' %>">Journal</a>
            <a href="/performance" class="<%= typeof activePage !== 'undefined' && activePage === 'performance' ? 'active' : '' %>">Performance</a>
            <a href="/exchange" class="<%= typeof activePage !== 'undefined' && activePage === 'exchange' ? 'active' : '' %>">Exchange</a>
            <% } %>
          </div>
        </div>

        <div class="nav-dropdown <%= ['analytics','crypto-alerts','themes','market-pulse'].indexOf(typeof activePage !== 'undefined' ? activePage : '') >= 0 ? 'active' : '' %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">Insights ▾</button>
          <div class="nav-dropdown-menu">
            <% if (typeof user !== 'undefined' && user) { %>
            <a href="/analytics" class="<%= typeof activePage !== 'undefined' && activePage === 'analytics' ? 'active' : '' %>">Analytics</a>
            <a href="/crypto-alerts" class="<%= typeof activePage !== 'undefined' && activePage === 'crypto-alerts' ? 'active' : '' %>">Crypto Alerts</a>
            <% } %>
            <a href="/themes" class="<%= typeof activePage !== 'undefined' && activePage === 'themes' ? 'active' : '' %>">Themes</a>
            <a href="/market-pulse" class="<%= typeof activePage !== 'undefined' && activePage === 'market-pulse' ? 'active' : '' %>">Market Pulse</a>
          </div>
        </div>

        <div class="nav-dropdown <%= ['learning','comparison','backtest','cache-status','free-signal'].indexOf(typeof activePage !== 'undefined' ? activePage : '') >= 0 ? 'active' : '' %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">Strategy ▾</button>
          <div class="nav-dropdown-menu">
            <a href="/learning" class="<%= typeof activePage !== 'undefined' && activePage === 'learning' ? 'active' : '' %>">Strategy Optimizer</a>
            <a href="/strategy-comparison" class="<%= typeof activePage !== 'undefined' && activePage === 'comparison' ? 'active' : '' %>">Compare</a>
            <a href="/backtest" class="<%= typeof activePage !== 'undefined' && activePage === 'backtest' ? 'active' : '' %>">Backtest</a>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
            <a href="/admin/cache-status" class="<%= typeof activePage !== 'undefined' && activePage === 'cache-status' ? 'active' : '' %>">Cache Status</a>
            <a href="/admin/free-signal" class="<%= typeof activePage !== 'undefined' && activePage === 'free-signal' ? 'active' : '' %>">Free Signal</a>
            <% } %>
          </div>
        </div>

        <% if (typeof user !== 'undefined' && user) { %>
        <div class="nav-dropdown <%= ['llm-chat','llm-logs'].indexOf(typeof activePage !== 'undefined' ? activePage : '') >= 0 ? 'active' : '' %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">AI ▾</button>
          <div class="nav-dropdown-menu">
            <a href="/llm-chat" class="<%= typeof activePage !== 'undefined' && activePage === 'llm-chat' ? 'active' : '' %>">LLM Chat</a>
            <a href="/llm-logs" class="<%= typeof activePage !== 'undefined' && activePage === 'llm-logs' ? 'active' : '' %>">LLM Logs</a>
          </div>
        </div>
        <% } %>

        <a href="/pricing" class="<%= typeof activePage !== 'undefined' && activePage === 'pricing' ? 'active' : '' %>">Pricing</a>
        <a href="/learn" class="<%= typeof activePage !== 'undefined' && activePage === 'learn' ? 'active' : '' %>">Learn</a>
        <% if (typeof user !== 'undefined' && user && (user.subscriptionTier === 'partner' || user.isPartner)) { %>
          <a href="/partner-dashboard" class="<%= typeof activePage !== 'undefined' && activePage === 'partner-dashboard' ? 'active' : '' %>">Partner</a>
        <% } %>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <a href="/trench-warfare" class="<%= typeof activePage !== 'undefined' && activePage === 'trench-warfare' ? 'active' : '' %>">Trench Warfare</a>
          <a href="/admin/referrals" class="<%= typeof activePage !== 'undefined' && activePage === 'admin-referrals' ? 'active' : '' %>">Referrals</a>
          <a href="/admin/beta" class="<%= typeof activePage !== 'undefined' && activePage === 'admin-beta' ? 'active' : '' %>">Beta</a>
        <% } %>
      </div>
      <div class="nav-right">
        <% if (typeof user !== 'undefined' && user) { %>
          <span class="nav-balance" title="Total equity: cash + margin + unrealized P&L<%= (typeof balance === 'number' && balance === 0) ? ' — Reset from Performance page' : '' %>">$<%= (typeof totalEquity === 'number' && !isNaN(totalEquity) && totalEquity >= 0) ? totalEquity.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : ((typeof balance === 'number' && !isNaN(balance) && balance >= 0) ? balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '10,000.00') %></span><% if (typeof balance === 'number' && balance === 0) { %><a href="/performance" style="margin-left:6px;font-size:11px;color:#f59e0b;" title="Reset paper account">Reset</a><% } %>
          <% if (typeof livePnl !== 'undefined' && livePnl !== null) { %>
          <span class="nav-pnl <%= livePnl > 0.01 ? 'pnl-positive' : (livePnl < -0.01 ? 'pnl-negative' : 'pnl-zero') %>" id="nav-live-pnl"><%= livePnl >= 0 ? '+' : '' %>$<%= livePnl.toFixed(2) %> PNL</span>
          <% } else { %>
          <span class="nav-pnl" id="nav-live-pnl"></span>
          <% } %>
          <span class="nav-user"><%= user.username %></span>
          <a href="/logout" class="nav-btn">Logout</a>
        <% } else { %>
          <a href="/login" class="nav-btn">Login</a>
          <a href="/register" class="nav-btn primary">Sign Up</a>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="main-content">
