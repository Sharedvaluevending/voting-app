<%- include('partials/header') %>
<div class="auth-container">
  <div class="auth-logo">
    <img src="/images/logo-full.png" alt="AlphaConfluence">
  </div>
  <div class="form-card">
    <h2>Create Account</h2>
    <% if (typeof betaEnabled !== 'undefined' && betaEnabled) { %>
    <p class="subtitle" style="color:#f59e0b;">Closed Beta — Access code required</p>
    <% } else { %>
    <p class="subtitle">Start your 14-day free trial with $10,000 paper balance</p>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof googleAuthEnabled !== 'undefined' && googleAuthEnabled) { %>
    <a href="/auth/google" class="form-btn" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px;text-decoration:none;background:#4285f4;color:#fff;border:none;">
      <svg width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Continue with Google
    </a>
    <p style="text-align:center;color:#6b7280;font-size:12px;margin:0 0 12px 0;">— or —</p>
    <% } %>
    <form action="/register" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="selectedPlan" value="<%= typeof selectedPlan !== 'undefined' ? selectedPlan : '' %>">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" required minlength="3" maxlength="20" placeholder="trader123">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" required placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required minlength="6" placeholder="Min 6 characters">
      </div>
      <% if (typeof betaEnabled !== 'undefined' && betaEnabled) { %>
      <div class="form-group">
        <label>Beta Access Code <span style="color:#ef4444;">*</span></label>
        <input type="text" name="betaAccessCode" required placeholder="BETA-XXXXXXXX" style="text-transform:uppercase;letter-spacing:1px;">
      </div>
      <% } %>
      <div class="form-group">
        <label>Referral code (optional)</label>
        <input type="text" name="referralCode" id="referralCodeInput" placeholder="CHAD10" value="<%= typeof referralCode !== 'undefined' ? referralCode : '' %>">
        <span id="referralStatus" style="display:block;margin-top:6px;font-size:12px;color:#9ca3af;"></span>
      </div>
      <button type="submit" class="form-btn">Create Account</button>
    </form>
    <p class="form-link">Already have an account? <a href="/login">Log in</a></p>
  </div>
</div>
<script>
  (function () {
    const input = document.getElementById('referralCodeInput');
    const status = document.getElementById('referralStatus');
    if (!input || !status) return;

    function setStatus(text, ok) {
      status.textContent = text || '';
      status.style.color = ok == null ? '#9ca3af' : (ok ? '#10b981' : '#ef4444');
    }

    async function validateReferralCode(code) {
      const value = String(code || '').trim().toUpperCase();
      if (!value) {
        setStatus('', null);
        return;
      }
      try {
        const res = await fetch('/api/referral/validate?code=' + encodeURIComponent(value));
        const out = await res.json();
        if (res.ok && out.valid) {
          setStatus('Code applied!', true);
        } else {
          setStatus(out.error || 'Invalid referral code', false);
        }
      } catch (err) {
        setStatus('Could not validate referral code', false);
      }
    }

    input.addEventListener('blur', function () {
      validateReferralCode(input.value);
    });

    const urlParams = new URLSearchParams(window.location.search);
    const refCode = urlParams.get('ref');
    if (refCode) {
      input.value = refCode.toUpperCase();
      validateReferralCode(refCode);
      document.cookie = 'ref=' + encodeURIComponent(refCode) + ';max-age=2592000;path=/';
    }
  })();
</script>
<%- include('partials/footer') %>
