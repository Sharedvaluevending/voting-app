<%- include('partials/header') %>

<div class="section-header">
  <h2 style="color:#fff;font-size:22px;">Strategy Builder</h2>
  <p style="color:#9ca3af;font-size:13px;margin-top:6px;">Build custom indicator-based strategies. Pick presets, backtest, and save your best combinations.</p>
</div>

<div class="section" style="margin-bottom:20px;padding:16px;background:rgba(15,23,42,0.6);border:1px solid #1e2a3a;border-radius:8px;">
  <h3 style="color:#eab308;font-size:12px;margin:0 0 8px 0;text-transform:uppercase;">How it works</h3>
  <p style="font-size:12px;color:#9ca3af;margin:0;line-height:1.6;">Use a preset or <strong>Build custom</strong> to pick from 18+ indicators (EMA, RSI, MACD, Bollinger, Stochastic, Keltner, Donchian, VWAP, etc.). Adjust period, multiplier, and overbought/oversold levels for each. Run backtest, save, and use for auto-trade.</p>
</div>

<div class="section" style="margin-bottom:24px;">
  <h3 style="color:#e5e7eb;margin-bottom:12px;">Strategy</h3>
  <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
      <input type="radio" name="sb-mode" value="preset" id="sb-mode-preset" checked>
      <span style="font-size:13px;color:#9ca3af;">Use preset</span>
    </label>
    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
      <input type="radio" name="sb-mode" value="custom" id="sb-mode-custom">
      <span style="font-size:13px;color:#9ca3af;">Build custom</span>
    </label>
  </div>

  <div id="sb-preset-wrap">
  <form id="sb-form" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;align-items:end;">
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Preset</label>
      <select id="sb-preset" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <option value="">-- Select preset --</option>
        <% presets.forEach(function(p) { %>
        <option value="<%= p.id %>"><%= p.name %> (Tier <%= p.tier %>)</option>
        <% }); %>
      </select>
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Coin</label>
      <select id="sb-coin" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
        <% (TRACKED_COINS || ['bitcoin','ethereum','solana']).slice(0,10).forEach(function(cid) { %>
        <option value="<%= cid %>"><%= cid %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">Start</label>
      <input type="date" id="sb-start" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div>
      <label style="font-size:11px;color:#6b7280;display:block;margin-bottom:4px;">End</label>
      <input type="date" id="sb-end" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;">
    </div>
    <div style="display:flex;flex-direction:column;gap:4px;">
      <label style="font-size:11px;color:#6b7280;">Quick range</label>
      <div style="display:flex;gap:6px;">
        <button type="button" id="sb-30d" class="btn btn-outline btn-sm" style="padding:6px 10px;">30d</button>
        <button type="button" id="sb-90d" class="btn btn-outline btn-sm" style="padding:6px 10px;">90d</button>
      </div>
    </div>
    <div>
      <button type="submit" class="btn btn-primary" id="sb-run">Run Backtest</button>
    </div>
  </form>
  </div>

  <div id="sb-custom-wrap" style="display:none;padding:16px;background:rgba(30,42,58,0.5);border:1px solid #334155;border-radius:8px;margin-bottom:16px;">
    <h4 style="color:#e5e7eb;margin:0 0 8px 0;font-size:14px;">Build Custom Strategy — All Indicators</h4>
    <p style="font-size:12px;color:#6b7280;margin:0 0 16px 0;">Pick from 18+ indicators. Adjust period, multiplier, and levels for each.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <div>
        <label style="font-size:11px;color:#eab308;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:8px;">Entry condition</label>
        <select id="sb-custom-entry" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;margin-bottom:10px;">
          <option value="">-- Select indicator --</option>
          <% (indicatorCatalog || []).forEach(function(ind) { %>
          <option value="<%= ind.id %>" data-group="<%= ind.group %>"><%= ind.group %>: <%= ind.name %></option>
          <% }); %>
        </select>
        <div id="sb-entry-params" style="display:grid;gap:8px;"></div>
      </div>
      <div>
        <label style="font-size:11px;color:#eab308;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:8px;">Exit condition</label>
        <select id="sb-custom-exit" style="width:100%;padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;margin-bottom:10px;">
          <option value="">-- Select indicator --</option>
          <% (indicatorCatalog || []).forEach(function(ind) { %>
          <option value="<%= ind.id %>" data-group="<%= ind.group %>"><%= ind.group %>: <%= ind.name %></option>
          <% }); %>
        </select>
        <div id="sb-exit-params" style="display:grid;gap:8px;"></div>
      </div>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="sb-apply-custom" style="margin-top:16px;">Apply Custom Strategy</button>
  </div>
</div>

<% if (typeof user !== 'undefined' && user && savedStrategies && savedStrategies.length > 0) { %>
<div class="section" style="margin-bottom:24px;">
  <h3 style="color:#e5e7eb;margin-bottom:12px;">Saved Strategies</h3>
  <div style="display:flex;flex-wrap:wrap;gap:8px;">
    <% savedStrategies.forEach(function(s) { %>
    <button type="button" class="btn btn-outline btn-sm sb-load-saved" data-id="<%= s._id %>" data-name="<%= s.name %>" data-entry="<%= JSON.stringify(s.entry).replace(/"/g, '&quot;') %>" data-exit="<%= JSON.stringify(s.exit).replace(/"/g, '&quot;') %>" style="padding:6px 12px;"><%= s.name %></button>
    <% }); %>
  </div>
</div>
<% } %>

<div id="sb-results" class="section" style="display:none;background:rgba(15,23,42,0.6);">
  <h3 style="color:#e5e7eb;margin-bottom:12px;">Results</h3>
  <div id="sb-summary" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;margin-bottom:16px;"></div>
  <div id="sb-trades-wrap" style="max-height:300px;overflow-y:auto;">
    <table class="data-table" style="background:rgba(15,23,42,0.4);">
      <thead><tr><th>#</th><th>Direction</th><th>Entry</th><th>Exit</th><th>PnL</th></tr></thead>
      <tbody id="sb-trades"></tbody>
    </table>
  </div>
  <% if (typeof user !== 'undefined' && user) { %>
  <div style="margin-top:16px;display:flex;gap:8px;">
    <input type="text" id="sb-save-name" placeholder="Strategy name" style="padding:8px 12px;background:#0d1320;border:1px solid #1e2a3a;border-radius:6px;color:#e5e7eb;font-size:13px;width:200px;">
    <button type="button" class="btn btn-primary" id="sb-save-btn">Save Strategy</button>
  </div>
  <% } %>
</div>

<div id="sb-error" style="display:none;padding:12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;color:#ef4444;margin-top:16px;"></div>

<script>
(function() {
  var presets = <%- JSON.stringify(presets) %>;
  var currentStrategy = null;
  var lastResult = null;

  function setDefaultDates() {
    var end = new Date();
    var start = new Date(end);
    start.setDate(start.getDate() - 30);
    document.getElementById('sb-end').value = end.toISOString().slice(0,10);
    document.getElementById('sb-start').value = start.toISOString().slice(0,10);
  }
  setDefaultDates();

  var sb30 = document.getElementById('sb-30d');
  if (sb30) sb30.addEventListener('click', function() {
    var end = new Date();
    var start = new Date(end);
    start.setDate(start.getDate() - 30);
    document.getElementById('sb-end').value = end.toISOString().slice(0,10);
    document.getElementById('sb-start').value = start.toISOString().slice(0,10);
  });
  var sb90 = document.getElementById('sb-90d');
  if (sb90) sb90.addEventListener('click', function() {
    var end = new Date();
    var start = new Date(end);
    start.setDate(start.getDate() - 90);
    document.getElementById('sb-end').value = end.toISOString().slice(0,10);
    document.getElementById('sb-start').value = start.toISOString().slice(0,10);
  });

  if (presets.length > 0) {
    document.getElementById('sb-preset').value = presets[0].id;
    currentStrategy = { entry: presets[0].entry, exit: presets[0].exit };
  }

  document.querySelectorAll('input[name="sb-mode"]').forEach(function(r) {
    r.addEventListener('change', function() {
      var isCustom = this.value === 'custom';
      document.getElementById('sb-preset-wrap').style.display = isCustom ? 'none' : 'block';
      document.getElementById('sb-custom-wrap').style.display = isCustom ? 'block' : 'none';
      if (isCustom) updateCustomParams();
    });
  });

  var indicatorCatalog = <%- JSON.stringify(indicatorCatalog || []) %>;

  function renderParams(divId, prefix, indicatorId) {
    var ind = indicatorCatalog.find(function(x) { return x.id === indicatorId; });
    var div = document.getElementById(divId);
    div.innerHTML = '';
    if (!ind || !ind.params || ind.params.length === 0) return;
    ind.params.forEach(function(p) {
      var wrap = document.createElement('div');
      wrap.style.display = 'flex';
      wrap.style.alignItems = 'center';
      wrap.style.gap = '8px';
      var lbl = document.createElement('label');
      lbl.textContent = p.label + ':';
      lbl.style.fontSize = '12px';
      lbl.style.color = '#9ca3af';
      lbl.style.minWidth = '90px';
      wrap.appendChild(lbl);
      if (p.type === 'number') {
        var inp = document.createElement('input');
        inp.type = 'number';
        inp.id = prefix + '-' + p.key;
        inp.value = p.default;
        if (p.min != null) inp.min = p.min;
        if (p.max != null) inp.max = p.max;
        inp.style.cssText = 'width:70px;padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:4px;color:#e5e7eb;font-size:12px;';
        wrap.appendChild(inp);
      } else if (p.type === 'select') {
        var sel = document.createElement('select');
        sel.id = prefix + '-' + p.key;
        sel.style.cssText = 'padding:6px 8px;background:#0d1320;border:1px solid #1e2a3a;border-radius:4px;color:#e5e7eb;font-size:12px;min-width:160px;';
        (p.options || []).forEach(function(opt) {
          var o = document.createElement('option');
          o.value = opt.value;
          o.textContent = opt.label;
          if (String(opt.value) === String(p.default)) o.selected = true;
          sel.appendChild(o);
        });
        if (!sel.value && p.options && p.options[0]) sel.value = p.options[0].value;
        wrap.appendChild(sel);
      } else if (p.type === 'checkbox') {
        var cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.id = prefix + '-' + p.key;
        cb.checked = !!p.default;
        wrap.appendChild(cb);
      }
      div.appendChild(wrap);
    });
  }

  function buildCondition(prefix, indicatorId) {
    var ind = indicatorCatalog.find(function(x) { return x.id === indicatorId; });
    if (!ind) return null;
    var rule = { type: ind.ruleType };
    if (ind.extra) for (var k in ind.extra) rule[k] = ind.extra[k];
    (ind.params || []).forEach(function(p) {
      var el = document.getElementById(prefix + '-' + p.key);
      var val;
      if (!el) val = p.default;
      else if (p.type === 'number') val = parseFloat(el.value);
      else if (p.type === 'checkbox') val = el.checked;
      else val = el.value;
      if (val !== undefined && val !== null) rule[p.key] = p.type === 'number' ? (Number(val) || p.default) : val;
      else rule[p.key] = p.default;
    });
    return rule;
  }

  function updateCustomParams() {
    var entry = document.getElementById('sb-custom-entry').value;
    var exit = document.getElementById('sb-custom-exit').value;
    renderParams('sb-entry-params', 'sb-entry', entry);
    renderParams('sb-exit-params', 'sb-exit', exit);
  }

  document.getElementById('sb-custom-entry').addEventListener('change', updateCustomParams);
  document.getElementById('sb-custom-exit').addEventListener('change', updateCustomParams);
  document.getElementById('sb-apply-custom').addEventListener('click', function() {
    var entryId = document.getElementById('sb-custom-entry').value;
    var exitId = document.getElementById('sb-custom-exit').value;
    if (!entryId || !exitId) {
      alert('Select both entry and exit indicators.');
      return;
    }
    var entry = buildCondition('sb-entry', entryId);
    var exit = buildCondition('sb-exit', exitId);
    if (entry && exit) {
      currentStrategy = { entry: entry, exit: exit };
      document.getElementById('sb-preset').value = '';
      alert('Custom strategy applied. Click Run Backtest.');
    }
  });

  document.getElementById('sb-preset').addEventListener('change', function() {
    var id = this.value;
    var p = presets.find(function(x) { return x.id === id; });
    if (p) currentStrategy = { entry: p.entry, exit: p.exit };
    else currentStrategy = null;
  });

  document.querySelectorAll('.sb-load-saved').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentStrategy = { entry: JSON.parse(this.dataset.entry), exit: JSON.parse(this.dataset.exit) };
      document.getElementById('sb-save-name').value = this.dataset.name;
    });
  });

  document.getElementById('sb-form').addEventListener('submit', function(e) {
    e.preventDefault();
    if (!currentStrategy) {
      alert('Select a preset or load a saved strategy first.');
      return;
    }
    var btn = document.getElementById('sb-run');
    btn.disabled = true;
    btn.textContent = 'Running...';
    document.getElementById('sb-error').style.display = 'none';

    fetch('/api/strategy-builder/backtest', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        coinId: document.getElementById('sb-coin').value,
        startDate: document.getElementById('sb-start').value,
        endDate: document.getElementById('sb-end').value,
        strategy: currentStrategy,
        presetId: document.getElementById('sb-preset').value || null
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) throw new Error(data.error);
      lastResult = data;
      var s = data.summary || {};
      var rangeNote = data.dataRangeNote ? '<div style="grid-column:1/-1;font-size:11px;color:#6b7280;">Data: ' + data.dataRangeNote + '</div>' : '';
      document.getElementById('sb-summary').innerHTML = rangeNote +
        '<div style="padding:10px;background:rgba(30,42,58,0.5);border-radius:6px;"><div style="font-size:10px;color:#6b7280;">Trades</div><div style="font-size:18px;font-weight:700;">' + (s.totalTrades || 0) + '</div></div>' +
        '<div style="padding:10px;background:rgba(30,42,58,0.5);border-radius:6px;"><div style="font-size:10px;color:#6b7280;">Win Rate</div><div style="font-size:18px;font-weight:700;color:#10b981;">' + (s.winRate || 0).toFixed(1) + '%</div></div>' +
        '<div style="padding:10px;background:rgba(30,42,58,0.5);border-radius:6px;"><div style="font-size:10px;color:#6b7280;">Total PnL</div><div style="font-size:18px;font-weight:700;' + ((s.totalPnl || 0) >= 0 ? 'color:#10b981' : 'color:#ef4444') + '">$' + (s.totalPnl || 0).toFixed(2) + '</div></div>' +
        '<div style="padding:10px;background:rgba(30,42,58,0.5);border-radius:6px;"><div style="font-size:10px;color:#6b7280;">Max DD</div><div style="font-size:18px;font-weight:700;color:#eab308;">' + (s.maxDrawdownPct || 0).toFixed(1) + '%</div></div>';
      var tbody = document.getElementById('sb-trades');
      tbody.innerHTML = '';
      (data.trades || []).slice(0, 50).forEach(function(t, i) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + (i+1) + '</td><td>' + (t.direction || 'LONG') + '</td><td>$' + (t.entry || 0).toFixed(4) + '</td><td>$' + (t.exit || 0).toFixed(4) + '</td><td style="' + ((t.pnl || 0) >= 0 ? 'color:#10b981' : 'color:#ef4444') + '">$' + (t.pnl || 0).toFixed(2) + '</td>';
        tbody.appendChild(tr);
      });
      if (!data.trades || data.trades.length === 0) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="5" style="text-align:center;color:#6b7280;padding:16px;">No trades in this period. Future dates have no data — use 30d or 90d buttons for recent history. Try RSI Mean Reversion preset for more signals.</td>';
        tbody.appendChild(tr);
      }
      document.getElementById('sb-results').style.display = 'block';
    })
    .catch(function(err) {
      document.getElementById('sb-error').textContent = err.message || 'Backtest failed';
      document.getElementById('sb-error').style.display = 'block';
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Run Backtest';
    });
  });

  document.getElementById('sb-save-btn').addEventListener('click', function() {
    var name = (document.getElementById('sb-save-name').value || '').trim();
    if (!name) { alert('Enter a strategy name'); return; }
    if (!currentStrategy) { alert('Run a backtest first'); return; }
    fetch('/api/strategy-builder/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: name,
        presetId: document.getElementById('sb-preset').value || null,
        timeframe: '1h',
        entry: currentStrategy.entry,
        exit: currentStrategy.exit
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) throw new Error(data.error);
      alert('Saved!');
      location.reload();
    })
    .catch(function(err) { alert(err.message); });
  });
})();
</script>

<%- include('partials/footer') %>
