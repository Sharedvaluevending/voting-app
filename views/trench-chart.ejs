<%- include('partials/header') %>

<div class="main-content-inner" style="padding:16px;">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:12px;">
    <h2 style="color:#fff;font-size:18px;margin:0;">Token Chart</h2>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <a href="<%= dexUrl %>" target="_blank" rel="noopener" class="nav-btn primary" style="padding:8px 14px;font-size:13px;text-decoration:none;">Open DexScreener</a>
      <a href="<%= birdeyeUrl %>" target="_blank" rel="noopener" class="nav-btn" style="padding:8px 14px;font-size:13px;text-decoration:none;">Open Birdeye</a>
      <a href="/trench-warfare" class="nav-btn" style="padding:8px 14px;font-size:13px;text-decoration:none;">← Trench Warfare</a>
    </div>
  </div>
  <p style="font-size:12px;color:#9ca3af;margin-bottom:12px;">Solana DEX chart. If the chart below is blank, use &quot;Open DexScreener&quot; (some browsers block embedding).</p>
  <div style="background:rgba(15,23,42,0.6);border:1px solid #1e2a3a;border-radius:8px;overflow:hidden;min-height:500px;">
    <iframe src="<%= dexUrl %>" title="DexScreener Chart" style="width:100%;height:600px;border:none;" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
  </div>
</div>

<%- include('partials/footer') %>
